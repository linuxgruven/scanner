GN=function(t);return "<color=#0ceb86>"+t+"</color>";end function
RD=function(t);return "<color=#f00>"+t+"</color>";end function
BL=function(t);return "<color=#00f>"+t+"</color>";end function
YL=function(t);return "<color=#ff0>"+t+"</color>";end function
WH=function(t);return "<color=#fff>"+t+"</color>";end function
OR=function(t);return "<color=#ffa500>"+t+"</color>";end function
PR=function(t);return "<color=#800080>"+t+"</color>";end function
LM=function(t);return "<color=#0f0>"+t+"</color>";end function
GY=function(t);return "<color=#888>"+t+"</color>";end function
LG=function(t);return "<color=#aaa>"+t+"</color>";end function
ER=function(t);return "<color=#f44>"+t+"</color>";end function
gco=get_custom_object
_hr=GN("═"*64)
_hb=function(t);n=(54-t.len)/2;return "═"*n+" "+t+" "+"═"*n;end function
_ui=@user_input
_HC=@host_computer
_hp=@has_permission
_vi=@is_valid_ip
_pn=@port_number
_gc=@get_content
_gr=@get_router
_p=@print
_s=@str
_to=@typeof
_ti=@to_int
_iv="Invalid selection"
_iip="Invalid IP"
_uu="    User: "
_uh="    Host: "
_up="    Path: "
_uc="Unsafe check"
_cm="computer"
_sh="shell"
_rs="/librshell.so"
_fs="ftpshell"
_mx="/metaxploit.so"
_rl="result"
_sg="string"
_gt="guest"
_sl="/var/system.log"
_rt="Result type: "
_uk="unknown"
_ch="chmod"
_bf="Build failed: "
_fd="Firewall disabled!"
_kr="kernel_router.so"
_lr="/lib/librshell.so"
_hd=function(u);if u=="root" then return "/root";return "/home/"+u;end function
_lj=function(text,width);if text.len>=width then return text;return text+(" "*(width-text.len));end function
cbool=function(v);if v then return GN("True") else return RD("False");end function
prt=function(msg,type="i")
  if type=="e" then _p RD("[!] ")+WH(msg)
  if type=="s" then _p OR("[+] ")+WH(msg)
  if type=="w" then _p YL("[!] ")+WH(msg)
  if type=="i" then _p YL("[i] ")+GY(msg)
end function
_pe=function(m);prt(m,"e");end function
_ps=function(m);prt(m,"s");end function
_pw=function(m);prt(m,"w");end function
_uig=function(x)
  if gco.H then return null
  r=_ui(GN(x))
  if r and _tl(r)=="home" then
    gco.H=true
    return null
  end if
  return r
end function
_tl=function(x);return x.trim.lower;end function
_mi=function(k,l);return GN("["+k+"]")+GY(l);end function
_bk=_mi("b","  Back")
_ns="Need a shell"
_en="  This exploit returned null during scan."
_gu=function(x)
  root=toRoot(x)
  if not root then return _gt
  for f in root.get_folders
    if f.name=="root" and _hp(f,"w") and _hp(f,"r") and _hp(f,"x") then return "root"
    if f.name=="home" then
      g=null
      for h in f.get_folders
        if h.name==_gt then
          g=h
          continue
        end if
        if _hp(h,"w") and _hp(h,"r") and _hp(h,"x") then return h.name
      end for
      if g then return _gt
      break
    end if
  end for
  return _gt
end function
toRoot=function(x)
  obj=_to(x)
  if obj==_cm then return x.File("/")
  if indexOf(obj,_sh)!=null then return _HC(x).File("/")
  if obj=="file" then
    f=x
    while f.parent;f=f.parent;end while
    return f
  end if
  return null
end function
getAllFiles=function(root)
  l=[]
  _=function(f);for z in f.get_files; l.push(z); end for;for d in f.get_folders;if d.is_symlink then continue;l.push(d);_(d);end for;end function
  _(root)
  return l
end function
getFileEx=function(x,p)
  obj=_to(x)
  if obj==_cm then return x.File(p)
  if indexOf(obj,_sh)!=null then return _HC(x).File(p)
  if obj=="file" then
    root=toRoot(x)
    if not root then return null
    for f in getAllFiles(root);if f.path==p then return f;end for
  end if
  return null
end function
_cur=function
  pv=gco.pivots
  if pv and pv.len>0 then return pv[pv.len-1]
  return gco.home
end function
_scn=function;return gco.home;end function
_0dayMonths=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
_0dayDays=[31,28,31,30,31,30,31,31,30,31,30,31]
_getMonthDays=function(month,year);return _0dayDays[_0dayMonths.indexOf(month)]+(month=="Feb" and year%4==0);end function
_parseDate=function(raw)
  sep=raw.split("-")
  ds=sep[0].split("/")
  ts=sep[1].split(":")
  return {"day":_ti(ds[0]),"month":ds[1],"year":_ti(ds[2]),"hour":_ti(ts[0]),"min":_ti(ts[1])}
end function
_minsToIrlSecs=function(mins);return mins*(60/14);end function
_secsToHuman=function(secs)
  d=floor(secs/3600/24)
  h=floor(secs/3600)%24
  m=floor(secs/60)%60
  s=floor(secs)%60
  parts=[]
  if d>0 then parts.push(_s(d)+"d")
  if h>0 then parts.push(_s(h)+"h")
  if m>0 then parts.push(_s(m)+"m")
  if s>0 then parts.push(_s(s)+"s")
  if not parts then return "0s"
  return parts.join(" ")
end function
_getNext0dayMins=function(min,hour,day,month,year)
  mi=_0dayMonths.indexOf(month)+1
  dr=_getMonthDays(month,year)-day
  if mi%2==0 then dr=dr+_getMonthDays(_0dayMonths[mi%_0dayMonths.len],year)
  hr=23-hour%24
  mr=60-min
  hr=hr+dr*24
  mr=mr+hr*60
  return mr
end function
_remaining0day=function(raw)
  d=_parseDate(raw)
  mi=_0dayMonths.indexOf(d.month)+1
  if mi%2!=0 then return null
  if d.day>=15 then return null
  rd=14-d.day
  rh=24-d.hour+(rd*24)
  rm=60-d.min+(rh*60)
  return _secsToHuman(_minsToIrlSecs(rm))
end function
_calculate0day=function(raw)
d=_parseDate(raw);mins=_getNext0dayMins(d.min,d.hour,d.day,d.month,d.year);return _secsToHuman(_minsToIrlSecs(mins))
end function
_show0dayStatus=function
  raw=current_date
  rem=_remaining0day(raw)
  if rem then
    _p GN("[0DAY] ")+WH("ACTIVE! ")+YL(rem)+WH(" remaining (IRL)")
  else
    nxt=_calculate0day(raw)
    _p RD("[0DAY] ")+WH("Inactive. Next cycle in ")+YL(nxt)+WH(" (IRL)")
  end if
  d=_parseDate(raw)
  _p GY("  Game date: "+raw)
  mi=_0dayMonths.indexOf(d.month)+1
  if mi%2==0 and d.day<15 then
    _p GY("  Window: Day 1-14 of even months")
    _p GY("  Current: Day "+_s(d.day)+" of "+d.month+" (even month)")
  else
    if mi%2==0 then
      _p GY("  Day "+_s(d.day)+" of "+d.month+" — past day 14, window closed")
    else
      nextM=_0dayMonths[mi%_0dayMonths.len]
      _p GY("  Next window: "+nextM+" day 1-14")
    end if
  end if
end function
_sw=function(s,p);return s.indexOf(p)==0;end function
_ct=function(c,v);return c.indexOf(v)!=null;end function
_slvExtract=function(s,mark,d=" ")
  st=s.indexOf(mark)
  if st==null then return null
  sub=s[st+mark.len:]
  ep=sub.indexOf(d)
  if ep==null then return sub
  return sub[:ep]
end function
_slvExtractVar=function(s,mark)
  w=_slvExtract(s,mark," ")
  if w==null then return null
  c=w.indexOf(",")
  if c!=null then w=w[:c]
  return w
end function
_slvInsert=function(arr,idx,items);if not items isa list then items=[items];return arr[:idx+1]+items+arr[idx+1:];end function
_slvLineType=function(l)
  if _sw(l,"func_") then return "function"
  if _sw(l,"if ") then return "if"
  if _sw(l,"for ") then return "for"
  if _ct(l,"push") then return "listPush"
  if _ct(l,"[") and _ct(l,"]") then return "listSet"
  if _ct(l,"end") then return "end"
  return "other"
end function
_slvMath={"is equal to ":"== ","is not equal to ":"!= ","is greater than or equal to ":">= ","is less than or equal to ":"<= ","is greater than ":"> ","is less than ":"< ","minus ":"- ","plus ":"+ ","multiplied by ":"* ","multiplying it by ":"{VARNAME} * ","divided by ":"/ ","dividing it by ":"{VARNAME} / "}
_slvEq=function(s,v="{VARNAME}")
  for k in _slvMath.indexes;s=s.replace(k,_slvMath[k]);end for
  s=s.replace("{VARNAME}",v)
  l=s.split(" ")
  if l.len==3 and (l[1]=="*" or l[1]=="+") then
    if l[2]=="i" or len(l[2])>len(l[1]) then l.reverse
  end if
  return l.join(" ")
end function
_slvForRange=function(s);s=s.split(" to ");return "range("+s[0]+", "+s[1]+")";end function
_slvVD=function(V,fn,vn);if V[fn].indexOf(vn)==null then V[fn].push(vn);end function
_slvVU=function(V,A,fn,vn)
  if V[fn].indexOf(vn)==null then
    if A[fn].indexOf(vn)==null then A[fn].push(vn)
    V[fn].push(vn)
  end if
end function
_slvInitParse=function(r)
  p=[]
  i=[]
  for l in r.split(char(10))
    l=l.trim
    if l=="" or l=="Potential problems have been found in the following code:" then continue
    if l.indexOf(":")==null then i=i+l.split("\.") else p.push(l[l.indexOf(":")+2:])
  end for
  return {"program":p,"info":i}
end function
_slvParseInfo=function(info)
  if not info or not info isa list or not info.len then return null
  F=null
  V={}
  A={}
  p=info[0:]
  n=0
  while n<p.len
    l=p[n].trim
    if n!=0 and p[n-1]==p[n] and p[n]=="" then
      p.remove(n)
      continue
    end if
    if _sw(l,"and ") then l=l[4:]
    if _sw(l,"then ") then l=l[5:]
    parsed=null
    if _sw(l,"The function ") then
      fn=l[13:24]
      V[fn]=[]
      A[fn]=[]
      F=fn
      clauses=l[25:].split(", ")
      r=[fn+" = function()"]
      if _sw(clauses[0],"For each") or _sw(clauses[0],"If ") then r.push(clauses.join(", ")) else r=r+clauses
      parsed={_rl:r}
    else if _sw(l,"If the value of ") then
      parts=l.split(", ")
      r=["if "+_slvEq(parts[0][16:])+" then"]
      r=r+parts[1:]
      r.push("end if")
      parsed={_rl:r}
    else if _sw(l,"For each ") then
      lv=l[9:]
      lv=lv[:indexOf(lv," ")]
      rs=l[indexOf(l,lv)+lv.len+1:]
      rs=rs[:indexOf(rs,", ")]
      if _sw(rs,"from ") then rs=rs[5:]
      _slvVD(V,F,"i")
      body=l.split(", ")[1:]
      r=["for "+lv+" in "+_slvForRange(rs)]
      r=r+body
      r.push("end for")
      parsed={_rl:r}
    else if _sw(l,"creates a list ") then
      vn=_slvExtractVar(l,"creates a list ")
      _slvVD(V,F,vn)
      r=[vn+" = []"]
      r=r+l.split(", ")[1:]
      parsed={_rl:r}
    else if _sw(l,"assigns ") then
      tv=_slvExtract(l,"assigns "," ")
      _slvVD(V,F,tv)
      sa=_slvExtract(l," to the first element of "," ")
      _slvVU(V,A,F,sa)
      parsed={_rl:[tv+" = "+sa+"[0]"]}
    else if _sw(l,"calls the function ") then
      fn2=_slvExtract(l,"calls the function "," ")
      av=_slvExtract(l," with "," ")
      _slvVU(V,A,F,av)
      parsed={_rl:[av+" = "+fn2+"("+av+")"]}
    else if _sw(l,"adds ") then
      val=_slvExtract(l,"adds "," ")
      _slvVU(V,A,F,val)
      ln2=_slvExtract(l," to "," ")
      _slvVU(V,A,F,ln2)
      parsed={_rl:[ln2+".push("+val+")"]}
    else if _sw(l,"calculates ") then
      rv=_slvExtract(l,"calculates "," ")
      _slvVU(V,A,F,rv)
      parsed={_rl:[rv+" = "+_slvEq(l[11:],rv)]}
    else if _sw(l,"updates ") then
      uv=_slvExtract(l,"updates "," ")
      _slvVU(V,A,F,uv)
      expr=l[indexOf(l," by ")+4:]
      if _sw(expr,"calculating ") then expr=expr[12:]
      parsed={_rl:[uv+" = "+_slvEq(expr,uv)]}
    else if _sw(l,"Finally, it") then
      p[n]=l[11:]
      continue
    else if _sw(l,"returns ") then
      parsed={_rl:["return "+_slvEq(l[8:]),"end function"]}
    else
      p[n]=l
      n=n+1
      continue
    end if
    if parsed and parsed.result then
      p[n]=parsed.result[0]
      if parsed.result.len>1 then p=_slvInsert(p,n,parsed.result[1:])
    end if
    n=n+1
  end while
  out=[]
  indent=0
  for l in p
    y=_slvLineType(l)
    if y=="end" then indent=indent-1
    if y=="function" then
      m=l[:indexOf(l," ")]
      l=m+" = function("+join(A[m],", ")+")"
    end if
    out.push("    "*indent+l)
    if _ct(["function","if","for"],y) then indent=indent+1
  end for
  return out
end function
_slvSimilarity=function(a,b)
  y=a
  z=b
  a=a.split(" ")
  b=b.split(" ")
  bm={}
  for x in b;bm[x]=true;end for
  am={}
  for x in a;am[x]=true;end for
  s=0
  for x in a;if bm.hasIndex(x) then s=s+x.len+0.1;end for
  for x in b;if not am.hasIndex(x) then s=s-0.1;end for
  s=s-abs(y.len-z.len)/10
  return s
end function
_slvWrongTokens=function(a,b)
  y=a.split(" ")
  z=b.split(" ")
  am={}
  for x in y;am[x]=true;end for
  bm={}
  for x in z;bm[x]=true;end for
  s=0
  for x in am.indexes;if hasIndex(bm,x) then s=s+1;end for
  return (am.indexes.len-s+bm.indexes.len-s)/2
end function
_slvCompare=function(p,i)
  if not p or not i or not p.len or not i.len then return []
  r=[]
  a=0
  b=0
  while a<i.len and b<p.len
    c=p[b]!=i[a]
    if c and b<p.len and a+1<i.len then
      if _slvWrongTokens(p[b],i[a])>0.5 then
        if _slvLineType(p[b])!=_slvLineType(i[a]) then
          r.push(b+1)
          b=b-1
          c=false
        else
          ok=true
          offset=0
          while offset<=2
            pi=b+offset
            ii=a+offset+1
            if pi>=p.len or ii>=i.len then break
            cs=_slvSimilarity(p[pi],i[a+offset])
            ns=_slvSimilarity(p[pi],i[ii])
            if not (ns>cs or p[pi]==i[ii]) then
              ok=false
              break
            end if
            offset=offset+1
          end while
          if ok then
            r.push(b+1)
            b=b-1
            c=false
          end if
        end if
      end if
    end if
    if c then r.push(b+1)
    b=b+1
    a=a+1
  end while
  out=[]
  for x in r;if out.indexOf(x)==null then out.push(x);end for
  return out
end function
_slvSolve=function(raw)
  r=_slvInitParse(raw)
  f=_slvParseInfo(r.info)
  if not f then return null
  u=_slvCompare(r.program,f)
  return {"errors":u,"patch":f}
end function
_hasNet=function(c);p=c.public_ip;return p and p!="0.0.0.0";end function
_classifyEx=function(ex,ln)
  obj=_to(ex)
  eu=""
  if obj==_sh or obj==_fs then
    et=_sh;eu=_gu(ex)
  else if obj==_cm then
    if ln==_kr then et="bounce" else et=_cm
    eu=_gu(ex)
  else if obj=="file" then
    et="file";eu=_gu(ex)
  else if not ex then
    if ln==_kr then et="bounce" else et="null"
  else if ex isa number then
    if ln==_kr then et="firewall" else et=_uk
  else
    et=_uk
  end if
  return [et,eu]
end function
_exTag=function(e)
  t=e.type
  tc=@GY
  if t==_sh then tc=@GN
  if t==_cm then tc=@YL
  if t=="file" then tc=@RD
  if t=="bounce" then tc=@PR
  if t=="firewall" then tc=@LM
  ut=@GY;uv="-"
  if e.user=="root" then ut=@GN;uv=e.user
  if e.user==_gt then ut=@RD;uv=e.user
  if e.user!="" and e.user!="root" and e.user!=_gt then ut=@YL;uv=e.user
  return WH(_lj(_s(e.i),5))+tc(_lj(t,12))+ut(_lj(uv,12))+BL(_lj(e.addr,14))+GY(e.val)
end function
_debugSolve=function(dLib,_am=false)
  scanResult=dLib.scan
  if not scanResult then
    _pe("scan returned no results")
    return null
  end if
  _p OR("--- Debug Scan Output ---")
  lines=scanResult.split(char(10))
  for line in lines;if not line then continue;_p GY(_s(__line_idx+1)+": ")+WH(line);end for
  _p OR("-------------------------")
  _p ""
  if _am then
    mode="a"
  else
    modeAns=_ui(GN("[")+WH("a")+GN("]uto solve or [")+WH("m")+GN("]anual? > "))
    if not modeAns then return null
    mode=_tl(modeAns)
  end if
  if mode=="a" or mode=="auto" then
    prt("Auto-solving...")
    solved=_slvSolve(scanResult)
    if not solved or not solved.errors or not solved.errors.len then
      _pw("Auto-solve found no errors, switching to manual")
    else
      _ps("Error lines: "+join(solved.errors,", "))
      _p OR("--- Corrected Code ---")
      for l in solved.patch;_p GY(l);end for
      _p OR("----------------------")
      _p ""
      if _am then return solved
      ans=_uig("[Enter to accept, new line #s to override, 'm' manual] > ")
      if not ans or not len(ans.trim) then return solved
      if _tl(ans)!="m" then
        errLines=[]
        for pt in ans.trim.split(" ");nn=_ti(pt.trim);if nn isa number then errLines.push(nn);end for
        if errLines then solved.errors=errLines
        return solved
      end if
      _pw("Switching to manual")
    end if
  end if
  prt("Enter ER line numbers (space-separated)")
  ans=_uig("[Error lines] > ")
  if not ans or not len(ans.trim) or _tl(ans)=="b" then return null
  errLines=[]
  for pt in ans.trim.split(" ");nn=_ti(pt.trim);if nn isa number then errLines.push(nn);end for
  if not errLines then return null
  return {"errors":errLines,"patch":null}
end function
_getNeuroCreds=function
  if gco.hasIndex("neuro_creds") and gco.neuro_creds then return gco.neuro_creds
  prt("Neurobox engineer credentials required")
  u=_uig("[Neurobox user] > ")
  if not u or not u.trim.len then return null
  p=_uig("[Neurobox pass] > ")
  if not p or not p.trim.len then return null
  cred={"user":u.trim,"pass":p.trim}
  gco.neuro_creds=cred
  return cred
end function
_neuroScan=function
  prt("Neurobox IP Scanner — find target's public IP via email verification")
  e=_uig("[Your/a email address] > ")
  if not e or not e.trim.len then return _pe("Email required")
  e=e.trim
  p=_uig("[Email password] > ")
  if not p or not p.trim.len then return _pe("Password required")
  p=p.trim
  t=_uig("[Target name (from chat log)] > ")
  if not t or not t.trim.len then return _pe("Target name required")
  t=t.trim
  partial=_uig("[Partial IP] > ")
  if not partial or not partial.trim.len then return _pe("Partial IP required")
  partial=partial.trim
  if indexOf(partial,"XXX")==null then return _pe("IP must contain XXX as unknown octet")
  fi=indexOf(partial,"XXX")
  if indexOf(partial,"XXX",fi+3)!=null then partial=partial[:fi+3]+partial[fi+3:].replace("XXX","YYY")
  hasYYY=indexOf(partial,"YYY")!=null
  yStart=0
  skipN=10
  if hasYYY then
    ys=_uig("[2nd octet start (0-255, default 0)] > ")
    if ys and ys.trim.len then
      ys=_ti(ys.trim)
      if ys isa number and ys>=0 and ys<=255 then yStart=ys
    end if
    sk=_uig("[Skip after N misses (default 10, 0=off)] > ")
    if sk and sk.trim.len then
      sk=_ti(sk.trim)
      if sk isa number and sk>=0 then skipN=sk
    end if
  end if
  M=mail_login(e,p)
  if M isa string then return _pe("Mail login failed: "+M)
  if hasYYY then
    total=(256-yStart)*256
    _ps("Authenticated. Scanning "+_s(total)+" IPs (2 octets)...")
  else
    _ps("Authenticated. Scanning 256 IPs...")
  end if
  _cd=0
  _getNB=function(ip)
    d=whois(ip)
    if d.indexOf("Neurobox")!=null then return d.split(char(10))[0].replace("Domain name: www.","@")
    return null
  end function
  _testMail=function(addr)
    w=2-(time-outer._cd)
    if w>0.01 then wait(w)
    r=M.send(t+addr,t,t)
    outer._cd=time
    a=0
    while r==false and a<3;wait(1);a=a+1;r=M.send(t+addr,t,t);end while
    if r!=1 then return false else return true
  end function
  _tryIP=function(ip)
    d=_getNB(ip)
    if not d then return false
    _pw("Neurobox found at "+ip+" — verifying email...")
    n=_testMail(d)
    if n then
      _ps("NETWORK FOUND: "+ip)
      _ps("Domain: "+d)
      _ps("Time: "+_s(floor(time))+"s")
      return true
    end if
    return false
  end function
  if hasYYY then
    j=yStart
    while j<256
      base=partial.replace("YYY",_s(j))
      i=0
      ms=0
      while i<256
        u=base.replace("XXX",_s(i))
        i=i+1
        cnt=(j-yStart)*256+i
        if cnt%64==0 then _p GY("  Checked "+_s(cnt)+"... (YYY="+_s(j)+" XXX="+_s(i-1)+")")
        d=_getNB(u)
        if not d then
          ms=0
          continue
        end if
        _pw("Neurobox found at "+u+" — verifying email...")
        n=_testMail(d)
        if n then
          _ps("NETWORK FOUND: "+u)
          _ps("Domain: "+d)
          _ps("Time: "+_s(floor(time))+"s")
          return
        end if
        ms=ms+1
        if skipN>0 and ms>=skipN then
          _pw("Skipping octet "+_s(j)+" ("+_s(skipN)+"+ misses)")
          break
        end if
      end while
      j=j+1
    end while
  else
    i=0
    while i<256
      u=partial.replace("XXX",_s(i))
      i=i+1
      if i%16==0 then _p GY("  Checked "+_s(i)+"/256...")
      if _tryIP(u) then return
    end while
  end if
  _pw("No networks found")
end function
_patchLib=function(shell,lib)
  if not lib then return _pe("No library provided")
  if lib.is_patched then return _ps(lib.lib_name+" v"+lib.version+" already patched ("+lib.is_patched(1)+")")
  cred=_getNeuroCreds
  if not cred then return _pe("No credentials provided")
  dLib=lib.debug_tools(cred.user,cred.pass)
  if not dLib then return _pe("debug_tools returned null — bad credentials?")
  if _to(dLib)!="debugLibrary" then return _pe("debug_tools ER: "+dLib)
  prt("Scanning "+lib.lib_name+" v"+lib.version+"...")
  solved=_debugSolve(dLib,_am)
  if not solved then return _pw("Solve aborted")
  prt("Running unit_testing with lines: "+solved.errors.join(", "))
  testResult=dLib.unit_testing(solved.errors)
  if testResult then _p GY(testResult)
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  comp.touch(home,"_patch_.txt")
  pf=comp.File(home+"/_patch_.txt")
  if not pf then return _pe("Failed to create patch file")
  if solved.patch then
    pf.set_content(solved.patch.join(char(10)))
  else
    prt("No auto-generated patch. Enter patch code or 'b' to abort")
    pc=_uig("[patch] > ")
    if not pc or _tl(pc)=="b" then
      qrm(comp,pf)
      return _pw("Aborted")
    end if
    pf.set_content(pc.trim)
  end if
  prt("Applying patch...")
  r=dLib.apply_patch(pf.path)
  qrm(comp,pf)
  if r then _ps(r) else prt("apply_patch returned null")
end function
_patchMenu=function(shell)
  comp=_HC(shell)
  if shell==_ls then rMetax=_scn.metax else rMetax=_grM(shell)
  if not rMetax then return
  libDir=comp.File("/lib")
  if not libDir then return _pe("Cannot access /lib")
  libFiles=libDir.get_files
  if not libFiles then return _pe("No libraries found in /lib")
  while true
    if gco.H then break
    _p OR("--- Library Patching ---")
    _p GY(_lj("#",5))+GY(_lj("LIBRARY",25))+GY(_lj("VERSION",12))+GY("PATCHED")
    for lf in libFiles
      i=__lf_idx+1
      ml=load(rMetax,path(lf))
      if not ml then
        _p WH(_lj(_s(i),5))+YL(_lj(name(lf),25))+GY("(cannot load)")
        continue
      end if
      p=ml.is_patched(1)
      if p isa string then
        ps=GN("Yes ("+p+")")
      else if p==1 then
        ps=GN("Yes")
      else
        ps=RD("No")
      end if
      _p WH(_lj(_s(i),5))+YL(_lj(ml.lib_name,25))+BL(_lj(ml.version,12))+ps
    end for
    c=_uig("[# to patch, 'a' patch all unpatched, 'b' back] > ")
    if not c or _tl(c)=="b" then return
    if _tl(c)=="a" then
      for lf in libFiles
        ml=rMetax.load(path(lf))
        if not ml then continue
        if ml.is_patched then continue
        _patchLib(shell,ml)
      end for
      continue
    end if
    sel=_ti(c.trim)
    if not sel isa number or sel<1 or sel>libFiles.len then
      _pe(_iv)
      continue
    end if
    ml=rMetax.load(libFiles[sel-1].path)
    if not ml then
      _pe("Cannot load library")
      continue
    end if
    _patchLib(shell,ml)
  end while
end function
_poParsePData=function(testResult)
  mem=null
  vuln=null
  cperm=null
  fperm=null
  for l in testResult.split(char(10))
    if not l then continue
    if l.indexOf("A potential")!=null then
      mem=split(l," ")[-1]
    else if l.indexOf("New vulnerability found:")!=null then
      s=l.indexOf("<b>")
      e=l.indexOf("</b>")
      if s!=null and e!=null then vuln=l[s+3:e]
    else if l.indexOf("* Computer")!=null then
      if l.indexOf("[root]")!=null then
        cperm="root"
      else if l.indexOf("[normal_user]")!=null then
        cperm="user"
      else
        cperm=_gt
      end if
    else if l.indexOf("* File")!=null then
      if l.indexOf("[root]")!=null then
        fperm="root"
      else if l.indexOf("[normal_user]")!=null then
        fperm="user"
      else
        fperm=_gt
      end if
    end if
  end for
  return {"memory":mem,"vuln":vuln,"computer":cperm,"file":fperm}
end function
_poAcquire=function(dLib,memZone,libPath)
  prt("Executing payload...")
  if libPath then result=dLib.payload(memZone,libPath) else result=dLib.payload(memZone)
  if not result then return _pe("payload returned null")
  if _to(result)==_sg then return _pe("payload ER: "+result)
  if not result isa list or not result.len then return _pe("Unexpected payload result: "+_to(result))
  _pc=result[0]
  pfile=null
  pmlib=null
  if result.len>=2 then pfile=result[1]
  if result.len>=3 then pmlib=result[2]
  if not _pc then return _pe("No partial computer obtained")
  _ps("Got partial computer!")
  if pfile then _ps("Got partial file!")
  if pmlib then _ps("Got partial metalib!")
  return {"_pc":_pc,"pfile":pfile,"pmlib":pmlib}
end function
_poScanLib=function(ml,dLib,_am=false)
  prt("Scanning "+ml.lib_name+" v"+ml.version+"...")
  solved=_debugSolve(dLib,_am)
  if not solved then return null
  prt("Running unit_testing...")
  testResult=dLib.unit_testing(solved.errors)
  if not testResult then return _pe("unit_testing returned null")
  _p GY(testResult)
  pd=_poParsePData(testResult)
  if pd.memory then
    _ps("Auto-detected memory zone: "+pd.memory)
    if pd.computer then _ps("Computer: ["+pd.computer+"]")
    if pd.file then _ps("File: ["+pd.file+"]")
    if not _am then
      ov=_uig("[Enter to use "+pd.memory+", or type a zone] > ")
      if ov and len(ov.trim) then pd.memory=ov.trim
    end if
  else
    _pw("Could not auto-detect memory zone")
    mz=_uig("[Memory zone (0x...)] > ")
    if not mz or not len(mz.trim) then return null
    pd.memory=mz.trim
  end if
  _poSaveExploit(ml,pd)
  return {"dLib":dLib,"pd":pd,"ml":ml}
end function
_poSaveExploit=function(ml,pd)
  if not pd.vuln or not pd.memory then return
  entry=ml.lib_name+" v"+ml.version+" @ "+pd.memory+" "+pd.vuln
  comp=_HC(get_shell)
  u=_gu(get_shell)
  home=_hd(u)
  f=comp.File(home+"/0day_exploits")
  if f then
    content=_gc(f)
    if content then
      for line in content.split(char(10));if line==entry then return;end for
      f.set_content(content+char(10)+entry)
    else
      f.set_content(entry)
    end if
  else
    comp.touch(home,"0day_exploits")
    f=comp.File(home+"/0day_exploits")
    if f then f.set_content(entry)
  end if
  _ps("Saved exploit: "+entry)
end function
_pObjectMenu=function(_poShell=null)
  if _poShell then
    hMetax=_grM(_poShell)
    if not hMetax then return _pe("Cannot load metaxploit on remote")
    comp=_HC(_poShell)
  else
    hMetax=_scn.metax
    if not hMetax then return _pe("Scan metaxploit not loaded")
    comp=_lc
  end if
  libDir=comp.File("/lib")
  pip=comp.public_ip
  lip=comp.local_ip
  router=_gr(pip)
  _al={}
  _lo=[]
  libCache={}
  _cc={}
  fmap={_ch:_ch,"cp":"copy","mv":"move","rm":"delete","rename":"rename","rn":"rename","chown":"set_owner","chgrp":"set_group"}
  curDLib=null
  curPD=null
  curML=null
  _pc=null
  pfile=null
  pmlib=null
  _tip=null
  while true
    if gco.H then break
    _p OR(_hb("PObject"))
    _p GY("  Public: ")+YL(pip)+GY("  Local: ")+YL(lip)
    if router then
      _p ""
      _p GY("  --- Local Edge Router Ports (")+YL(router.local_ip)+GY(") ---")
      _p YL("  0   ")+GN(_lj(router.local_ip,16))+WH("kernel_router")
      for p in router.used_ports;if p.is_closed then continue;_p YL("  "+_lj(_s(_pn(p)),4))+GN(_lj(p.get_lan_ip,16))+WH(router.port_info(p));end for
    end if
    if libDir then
      _p ""
      _p GY("  --- Local Libraries (/lib) ---")
      libFiles=libDir.get_files
      if libFiles then
        for lf in libFiles
          ml2=hMetax.load(lf.path)
          if ml2 then
            pt=ml2.is_patched(1)
            if pt isa string then
              ps=GN(" [P:"+pt+"]")
            else if pt==1 then
              ps=GN(" [P]")
            else
              ps=""
            end if
            _p GY("  "+_lj(_s(__lf_idx+1),4))+YL(_lj(lf.name,22))+BL(ml2.version)+ps
          else
            _p GY("  "+_lj(_s(__lf_idx+1),4))+YL(_lj(lf.name,22))+GY("(cannot load)")
          end if
        end for
      end if
    end if
    _p ""
    if _am then am=GN(" ON") else am=GY(" OFF")
    _p _mi("auto"," Auto-accept prompts:")+am
    _p _mi("scan"," Scan: ip:port, lib name/path, or # from list")
    _p _mi("nr","  Neuro scan (find target IP via email)")
    _psh=_poShell
    if not _psh then _psh=_ls
    if _psh and _gu(_psh)=="root" then _p _mi("pt","  Patch libs")
    _p _bk
    c=_uig("[po] > ")
    if not c or _tl(c)=="b" then return
    ch=c.trim
    if ch.lower=="nr" then
      _neuroScan
      continue
    end if
    if ch.lower=="auto" or ch.lower=="a" then
      _am=not _am
      if _am then _ps("Auto mode ON") else prt("Auto mode OFF")
      continue
    end if
    if ch.lower=="pt" then
      _psh=_poShell
      if not _psh then _psh=_ls
      if _psh and _gu(_psh)=="root" then _patchMenu(_psh) else _pe("Root shell required")
      continue
    end if
    if ch.lower[:5]=="scan " then ch=trim(ch[5:])
    ml=null
    libPath=null
    sn=_ti(ch)
    if sn isa number and libFiles and sn>=1 and sn<=libFiles.len then ch=libFiles[sn-1].name
    chParts=split(ch," ")
    if chParts.len==2 and _vi(chParts[0]) then ch=chParts[0]+":"+chParts[1]
    if ch.indexOf(":")!=null then
      rp=ch.split(":")
      ip=rp[0]
      pt=_ti(rp[1])
      if not _vi(ip) or not pt isa number then
        _pe("Format: ip:port (e.g. 1.2.3.4:22)")
        continue
      end if
      prt("Connecting to "+ip+":"+_s(pt)+"...")
      ml=dump_lib(net_use(hMetax,ip,pt))
      if not ml then
        _pe("dump_lib returned null for "+ip+":"+_s(pt))
        continue
      end if
      if _to(ml)==_sg then
        _pe("dump_lib ER: "+ml)
        continue
      end if
      libPath="/lib/"+lib_name(ml)
    else
      lch=ch.lower
      if lch.indexOf("/")==null then lch="/lib/"+lch
      if lch.indexOf(".so")==null then lch=lch+".so"
      ml=hMetax.load(lch)
      if not ml then
        _pe("Cannot load "+lch)
        continue
      end if
      libPath=lch
    end if
    if ml.is_patched(1) then
      _ps(ml.lib_name+" v"+ml.version+" patched "+ml.is_patched(1))
      continue
    end if
    cred=_getNeuroCreds
    if not cred then continue
    dLib=ml.debug_tools(cred.user,cred.pass)
    if not dLib then
      _pe("debug_tools returned null")
      continue
    end if
    if _to(dLib)!="debugLibrary" then
      _pe("debug_tools ER: "+dLib)
      continue
    end if
    sr=_poScanLib(ml,dLib,_am)
    if not sr then continue
    po=_poAcquire(sr.dLib,sr.pd.memory,libPath)
    if not po then continue
    curDLib=sr.dLib
    curPD=sr.pd
    curML=ml
    if pip then _tip=pip
    gco._eip=_tip
    _pc=po._pc
    pfile=po.pfile
    pmlib=po.pmlib
    ref={"file":"file","create_folder":"mkdir","touch":"touch","show_procs":"ps","change_password":"passwd","create_user":"useradd","delete_user":"userdel","create_group":"groupadd","delete_group":"groupdel","close_program":"kill"}
    fileRef={_ch:_ch,"copy":"cp","move":"mv","rename":"rn","delete":"rm","set_owner":"chown","set_group":"chgrp"}
    _cm2=[]
    _fm=[]
    for idx in _pc.__isa.indexes;if ref.hasIndex(idx) then _cm2.push(ref[idx]);end for
    if pfile then
      for idx in pfile.__isa.indexes;if fileRef.hasIndex(idx) then _fm.push(fileRef[idx]);end for
    end if
    pm={}
    _autoFn=function;outer._am=not _am;if _am then _ps("Auto mode ON") else prt("Auto mode OFF");end function
    pm.auto=@_autoFn
    pm.a=@_autoFn
    pm.probe=function
      if not argv.len then return prt("Usage: probe <path>")
      pp=argv[0]
      r=curDLib.payload(curPD.memory,pp)
      if r isa list and r.len>=2 and _to(r[1])=="pfile" then _pe("Exists: "+pp,"s") else prt("Not found: "+pp)
    end function
    pm.meta=function
      mlib=null
      if argv.len and _al.hasIndex(argv[0]) then
        mlib=_al[argv[0]][2]
      else if argv.len and argv[0].indexOf(".so")==null and _al.hasIndex(argv[0]+".so") then
        mlib=_al[argv[0]+".so"][2]
      else
        mlib=curML
      end if
      if not mlib then return _pe("No metalib available")
      mAddrs=hMetax.scan(mlib)
      if not mAddrs then return _pe("scan returned no addresses for "+mlib.lib_name)
      mExploits=[]
      lk=mlib.lib_name+"_"+mlib.version
      for ma in mAddrs
        vi=hMetax.scan_address(mlib,ma)
        if not vi then continue
        for vl in vi.split(char(10))
          if vl.indexOf(_uc)==0 then
            s=vl.indexOf("<b>")+3
            d=vl.indexOf("</b>")
            if s>2 and d!=null then mExploits.push({"addr":ma,"val":vl[s:d]})
          end if
        end for
      end for
      if not mExploits then return _pe("No exploits found for "+mlib.lib_name)
      prt("Running "+_s(mExploits.len)+" exploits...")
      oArg=null
      if _al.hasIndex(_kr) then
        rr=null
        if _tip then rr=_gr(_tip)
        if rr then oArg=rr.local_ip
      end if
      mResults=[]
      for me in mExploits
        if oArg then ex=mlib.overflow(me.addr,me.val,oArg) else ex=mlib.overflow(me.addr,me.val)
        ot=_to(ex)
        etype=_uk
        euser=""
        if ot==_sh or ot==_fs then
          etype=_sh
          euser=_gu(ex)
        else if ot==_cm then
          etype=_cm
          euser=_gu(ex)
        else if ot=="file" then
          etype="file"
        else if not ex then
          etype="null"
        else if ex isa number then
          etype="firewall"
        else
          etype=_s(ot)
        end if
        mResults.push({"addr":me.addr,"val":me.val,"ex":ex,"type":etype,"user":euser})
        if not _cc.hasIndex(lk) then _cc[lk]={"a":me.addr,"v":me.val}
      end for
      while true
        if gco.H then break
        _p OR("--- Exploits: "+mlib.lib_name+" v"+mlib.version+" ---")
        _ei=1
        for mr in mResults
          tc=@GY
          if mr.type==_sh then tc=@GN
          if mr.type==_cm then tc=@BL
          if mr.type=="file" then tc=@YL
          ul=""
          if mr.user then ul=GY(" (")+WH(mr.user)+GY(")")
          _p GY(_lj(_s(_ei),4))+YL(mr.addr)+GY(" -> ")+tc(mr.type)+ul
          _ei=_ei+1
        end for
        ma2=_uig("[#|b] > ")
        if not ma2 or _tl(ma2)=="b" then break
        mi=_ti(ma2.trim)
        if not mi isa number or mi<1 or mi>mResults.len then
          _pe(_iv)
          continue
        end if
        mr=mResults[mi-1]
        if mr.type==_sh or mr.type==_cm or mr.type=="file" then _exM(mr.ex,mr.type) else _pw(mr.addr+" → "+mr.type+" ("+_s(mr.ex)+")")
      end while
    end function
    pm.methods=function
      _p ""
      _p OR("Computer methods:")
      for idx in _pc.__isa.indexes;_p "  "+GN(idx);end for
      if pfile then
        _p OR("File methods:")
        for idx in pfile.__isa.indexes;_p "  "+GN(idx);end for
      end if
    end function
    pm.ports=function
      rr=null
      if _tip then rr=_gr(_tip)
      if not rr then rr=router
      if rr then
        _p YL("  0   ")+GN(_lj(_s(local_ip(rr)),16))+WH("kernel_router")
        for p in used_ports(rr);if is_closed(p) then continue;_p YL("  "+_lj(_s(_pn(p)),4))+GN(_lj(get_lan_ip(p),16))+WH(port_info(rr,p));end for
      else
        prt("No router available")
      end if
    end function
    pm.libs=function
      _libs=["init.so","kernel_module.so",_kr,"net.so","aptclient.so","crypto.so","metaxploit.so","libssh.so","libftp.so","libhttp.so","libsmtp.so","libsql.so","librshell.so","librepository.so","libcam.so","libchat.so","libsmartappliance.so","libtrafficnet.so"]
      _ln=1
      outer._al={}
      outer._lo=[]
      for l in _libs
        r=curDLib.payload(curPD.memory,"/lib/"+l)
        if r isa list and r.len==3 then
          rm=r[2]
          pt=rm.is_patched(1)
          if pt isa string then
            ps=GN(" [P:"+pt+"]")
          else if pt==1 then
            ps=GN(" [P]")
          else
            ps=""
          end if
          _p GY(_lj(_s(_ln),4))+YL(_lj(l,22))+BL(rm.version)+ps
          _al[l]=r
          _lo.push(l)
          _ln=_ln+1
        end if
      end for
      if libCache and libCache.len then
        _p OR("Cached partial libs:")
        for k in libCache.indexes;_p "  "+YL(k);end for
      end if
    end function
    pm.scan=function
      if not argv.len then return prt("Usage: scan <lib name|port>")
      sp=_ti(argv[0])
      if not sp isa number then
        lk=trim(argv[0])
        if lk.indexOf(".so")==null then lk=lk+".so"
        if _al.hasIndex(lk) and _al[lk] isa list then
          nml=_al[lk][2]
        else
          nml=null
          r=curDLib.payload(curPD.memory,"/lib/"+lk)
          if r isa list and r.len==3 then
            nml=r[2]
            _al[lk]=r
          end if
        end if
        if not nml then return _pe("Library "+lk+" not found on target")
        lp="/lib/"+lk
      else if sp>20 or sp==0 then
        tip=_tip
        if not tip then tip=pip
        prt("Connecting to "+_s(tip)+":"+_s(sp)+"...")
        nml=dump_lib(net_use(hMetax,tip,sp))
        if not nml or _to(nml)==_sg then return _pe("Failed to get lib from port "+_s(sp))
        lp="/lib/"+nml.lib_name
      else
        if not _lo or sp<1 or sp>_lo.len then return _pe("Invalid lib # (run libs first)")
        lk=_lo[sp-1]
        nml=_al[lk][2]
        if not nml then return _pe("Cannot load library")
        lp="/lib/"+lk
      end if
      if nml.is_patched then return _ps(nml.lib_name+" patched "+nml.is_patched(1))
      cred=_getNeuroCreds
      if not cred then return
      nd=nml.debug_tools(cred.user,cred.pass)
      if not nd or _to(nd)!="debugLibrary" then return _pe("debug_tools failed")
      sr=_poScanLib(nml,nd,_am)
      if not sr then return
      po=_poAcquire(sr.dLib,sr.pd.memory,lp)
      if not po then return
      outer.curDLib=sr.dLib
      outer.curPD=sr.pd
      outer.curML=nml
      outer._pc=po._pc
      outer.pfile=po.pfile
      outer.pmlib=po.pmlib
      outer._cm2=[]
      outer._fm=[]
      for idx in _pc.__isa.indexes;if ref.hasIndex(idx) then _cm2.push(ref[idx]);end for
      if pfile then
        for idx in pfile.__isa.indexes;if fileRef.hasIndex(idx) then _fm.push(fileRef[idx]);end for
      end if
    end function
    pm.mkdir=function
      if not argv.len then return _p(GY("mkdir <path>"))
      if _pc.__isa.hasIndex("create_folder") then
        r=_pc.create_folder(argv[0])
        if r==1 then
          _ps("Done")
          _poCommit(hMetax,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.touch=function
      if argv.len<2 then return _p(GY("touch <dir> <name>"))
      if _pc.__isa.hasIndex("touch") then
        r=_pc.touch(argv[0],argv[1])
        if r==1 then
          _ps("Done")
          _poCommit(hMetax,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.ps=function
      if _pc.__isa.hasIndex("show_procs") then
        r=_pc.show_procs
        if r then
          for p in r;_p GY(p.user+"  "+_s(p.pid)+"  "+p.program);end for
        end if
      end if
    end function
    pm.passwd=function
      if argv.len<2 then return _p(GY("passwd <user> <pass>"))
      if _pc.__isa.hasIndex("change_password") then
        r=_pc.change_password(argv[0],argv[1])
        if r==1 then
          _ps("Done")
          _poCommit(hMetax,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.useradd=function
      if argv.len<2 then return _p(GY("useradd <user> <pass>"))
      if _pc.__isa.hasIndex("create_user") then
        r=_pc.create_user(argv[0],argv[1])
        if r==1 then
          _ps("Done")
          _poCommit(hMetax,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.userdel=function
      if not argv.len then return _p(GY("userdel <user>"))
      if _pc.__isa.hasIndex("delete_user") then
        r=_pc.delete_user(argv[0])
        if r==1 then
          _ps("Done")
          _poCommit(hMetax,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.kill=function
      if not argv.len then return _p(GY("kill <pid>"))
      if _pc.__isa.hasIndex("close_program") then
        r=_pc.close_program(_ti(argv[0]))
        if r==1 then
          _ps("Done")
          _poCommit(hMetax,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    while true
      if gco.H then break
      _p OR("--- PObject Interpreter ---")
      if _am then am=GN("  Auto Enabled") else am=GY("  Auto Disabled")
      _p GY("  "+curML.lib_name+" v"+curML.version+" @ "+curPD.memory)
      _p am
      if curPD.computer then _p GN("  Computer: ["+curPD.computer+"]")
      if curPD.file then _p GN("  File:     ["+curPD.file+"]")
      if _cm2 then _p GN("  Comp: ")+WH(join(_cm2,", "))
      if _fm then _p GN("  File: ")+WH(join(_fm,", "))
      _p GN("  scan, probe, meta, libs, ports, methods, auto, exit")
      _p ""
      cmd=_ui(PR("[PObject] ")+WH(":~$ "))
      if not cmd or not len(cmd.trim) then continue
      parts=cmd.trim.split(" ")
      c0=lower(parts[0])
      argv=parts[1:]
      if c0=="exit" or c0=="b" or c0=="back" or c0=="quit" then break
      if hasIndex(pm,c0) then
        pm[c0]()
      else if fmap.hasIndex(c0) then
        fc=c0;if fc=="rn" then fc="rename"
        rflag=false
        if argv.len and (argv[0]=="-r" or argv[0]=="-R") then
          rflag=true
          argv=argv[1:]
        end if
        na=2;if fc=="rm" then na=1
        if argv.len>=na then
          pf=_poGetFile(curDLib,curPD.memory,argv[0])
          if pf and pf.__isa.hasIndex(fmap[fc]) then
            if fc=="cp" then
              dp=argv[1].split("/")
              dn=dp[-1]
              dd=dp[:-1].join("/")
              if not dd then dd="/"
              r=pf.copy(dd,dn)
            else if fc=="mv" then
              dp=argv[1].split("/")
              dn=dp[-1]
              dd=dp[:-1].join("/")
              if not dd then dd="/"
              r=pf.move(dd,dn)
            else if fc==_ch then
              perm=argv[1]
              if _ti(perm) isa number and perm.len==3 then
                r=null
                for ow in [[_ti(perm[0]),"u"],[_ti(perm[1]),"g"],[_ti(perm[2]),"o"]]
                  v=ow[0];w=ow[1]
                  if rflag then r=pf.chmod(w+"-rwx",rflag) else r=pf.chmod(w+"-rwx")
                  if r isa string and r.len then break
                  if bitAnd(v,4) then
                    if rflag then r=pf.chmod(w+"+r",rflag) else r=pf.chmod(w+"+r")
                    if r isa string and r.len then break
                  end if
                  if bitAnd(v,2) then
                    if rflag then r=pf.chmod(w+"+w",rflag) else r=pf.chmod(w+"+w")
                    if r isa string and r.len then break
                  end if
                  if bitAnd(v,1) then
                    if rflag then r=pf.chmod(w+"+x",rflag) else r=pf.chmod(w+"+x")
                    if r isa string and r.len then break
                  end if
                end for
              else
                if rflag then r=pf.chmod(perm,rflag) else r=pf.chmod(perm)
              end if
            else if fc=="rename" then
              r=pf.rename(argv[1])
            else if fc=="chown" then
              if rflag then r=pf.set_owner(argv[1],rflag) else r=pf.set_owner(argv[1])
            else if fc=="chgrp" then
              if rflag then r=pf.set_group(argv[1],rflag) else r=pf.set_group(argv[1])
            else
              if rflag then r=pf.delete(rflag) else r=pf.delete
            end if
            if fc=="cp" or fc=="mv" then ok=(r==1) else ok=not r
            if ok then
              _ps("Done")
              _poCommit(hMetax,pmlib,_al,_cc)
            else if r isa string then
              _p GY(r)
            end if
          end if
        else
          u={_ch:"[-r] <path> <perm|octal>","cp":"<path> <dst>","mv":"<path> <dst>","rm":"[-r] <path>","rename":"<path> <name>","chown":"[-r] <path> <user>","chgrp":"[-r] <path> <grp>"}
          _p GY(c0+" "+u[fc])
          if fc==_ch then _p GY("  octal: 777=rwx 755=rwxr-xr-x 700=rwx------ 644=rw-r--r--")
        end if
      else
        prt("Unknown: "+c0)
      end if
    end while
  end while
end function
_poCommit=function(mx,ml,aLibs,cache)
  libs=[]
  if ml then libs.push(ml)
  if aLibs then
    for k in aLibs.indexes
      if aLibs[k] isa list and len(aLibs[k])==3 and aLibs[k][2] then
        al=aLibs[k][2]
        if al!=ml then libs.push(al)
      end if
    end for
  end if
  for lb in libs;lk=lb.lib_name+"_"+lb.version;if cache.hasIndex(lk) then return lb.overflow(cache[lk].a,cache[lk].v);end for
  for lb in libs
    a=mx.scan(lb)
    if not a then continue
    vi=mx.scan_address(lb,a[0])
    if not vi then continue
    for l in vi.split(char(10))
      if l.indexOf(_uc)==0 then
        s=l.indexOf("<b>")+3
        d=l.indexOf("</b>")
        if s>2 and d!=null then
          lk=lb.lib_name+"_"+lb.version
          cache[lk]={"a":a[0],"v":l[s:d]}
          return lb.overflow(a[0],l[s:d])
        end if
      end if
    end for
  end for
end function
_poGetFile=function(dLib,memZone,filePath)
  r=dLib.payload(memZone,filePath)
  if not r then return _pe("payload returned null for "+filePath)
  if _to(r)==_sg then return _pe("payload ER: "+r)
  if not r isa list then return _pe("Unexpected result")
  for obj in r;if _to(obj)=="pfile" then return obj;end for
  return _pe("No pfile in payload result for "+filePath)
end function
_ppw=function(passwdFile)
  content=_gc(passwdFile)
  if not content then
    prt("passwd file is empty")
    return []
  end if
  entries=[]
  for line in content.split(char(10))
    if not line or not line.len then continue
    parts=line.split(":")
    if parts.len<2 then continue
    entries.push({"user":parts[0],"hash":parts[1]})
  end for
  if not entries then
    prt("No accounts found")
    return []
  end if
  _p GY(_lj("#",5))+GY(_lj("USER",16))+GY("HASH")
  for e in entries;i=__e_idx+1;_p WH(_lj(_s(i),5))+WH(_lj(e.user,16))+BL(e.hash);end for
  if not crypto then return []
  cracked=[]
  _p ""
  _p GY("  Enter # to crack, 'a' for all, or 'b' to skip")
  while true
    if gco.H then return cracked
    ans=_uig("[Crack #/a/b] > ")
    if not ans or _tl(ans)=="b" then return cracked
    if _tl(ans)=="a" then
      for e in entries
        _p YL("["+_s(__e_idx+1)+"/"+_s(entries.len)+"] ")+GY("Cracking "+e.user+"...")
        pass=decipher(crypto,e.hash)
        if not pass then
          _p WH(_lj(e.user,16))+RD("failed")
        else
          _p WH(_lj(e.user,16))+GN(pass)
          cracked.push({"user":e.user,"pass":pass})
        end if
      end for
      return cracked
    end if
    sel=_ti(ans.trim)
    if not sel isa number or sel<1 or sel>entries.len then
      _pe(_iv)
      continue
    end if
    e=entries[sel-1]
    prt("Cracking "+e.user+"...")
    pass=decipher(crypto,e.hash)
    if not pass then
      _p WH(_lj(e.user,16))+RD("failed")
    else
      _p WH(_lj(e.user,16))+GN(pass)
      cracked.push({"user":e.user,"pass":pass})
    end if
  end while
end function
wipeLog=function(x)
  obj=_to(x)
  if obj==_cm then comp=x
  if obj==_sh or obj==_fs then comp=_HC(x)
  if obj=="file" then
    root=toRoot(x)
    if not root then return _pe("Cannot resolve root from file object")
    logFile=null
    for f in getAllFiles(root)
      if f.path==_sl then
        logFile=f
        break
      end if
    end for
    if not logFile then return _pe("system.log not found")
    if not _hp(logFile,"w") then return _pe("No write permission to system.log")
    wf=null
    for f in getAllFiles(root)
      if f.path==_sl then continue
      if _hp(f,"r") and _hp(f,"w") then
        wf=f
        break
      end if
    end for
    if not wf then return _pe("No writable file found to use for wipe")
    wf.copy("/var","system.log")
    return _ps("system.log wiped")
  end if
  if not comp then return _pe("Cannot get computer from object")
  logFile=comp.File(_sl)
  if not logFile then return prt("system.log not found")
  if not _hp(logFile,"w") then return _pe("No write permission to system.log")
  r=comp.touch("/var","_t")
  if r isa string then
    if r=="The file already exists" then comp.File("/var/_t").move("/var","system.log") else return _pe(r)
  else if r isa number then
    comp.File("/var/_t").move("/var","system.log")
  else
    return _pe("Failed to create temp file")
  end if
  _ps("system.log wiped")
end function
qrm=function(comp,f)
  if not f then return
  p=f.parent
  if not p then return
  dir=p.path
  if not comp.File(dir+"/.111111111") then comp.create_folder(dir,".111111111")
  comp.create_folder(dir+"/.111111111",".111000111")
  f.move(dir+"/.111111111/.111000111","z")
  h=comp.File(dir+"/.111111111")
  if h then h.move(dir+"/.111111111/.111000111/","bye")
end function
_cwl=function(x)
  obj=_to(x)
  if obj==_cm then
    lf=x.File(_sl)
    if lf and _hp(lf,"w") then return true
    return false
  end if
  if obj==_sh or obj==_fs then
    lf=_HC(x).File(_sl)
    if lf and _hp(lf,"w") then return true
    return false
  end if
  if obj=="file" then
    root=toRoot(x)
    if not root then return false
    for f in getAllFiles(root)
      if f.path==_sl then
        if _hp(f,"w") then return true
        return false
      end if
    end for
  end if
  return false
end function
connectAs=function(creds,ex)
  if not creds then return prt("No cracked credentials available")
  _p ""
  _p GY("  Cracked credentials:")
  for c in creds;_p WH("  "+_s(__c_idx+1)+") ")+GN(c.user)+GY(" : ")+YL(c.pass);end for
  _p ""
  while true
    if gco.H then break
    ans=_uig("[Connect as #, or 'b' to skip] > ")
    if not ans or not len(ans.trim) then continue
    if _tl(ans)=="b" then return null
    ci=_ti(ans.trim)
    if not ci isa number or ci<1 or ci>creds.len then
      _pe(_iv)
      continue
    end if
    break
  end while
  cred=creds[ci-1]
  u=_gu(ex)
  comp=_HC(ex)
  home=_hd(u)
  hdir=comp.File(home)
  if not hdir or not _hp(hdir,"w") then
    home="/tmp"
    hdir=comp.File(home)
    if not hdir or not _hp(hdir,"w") then return _pe("No writable directory found")
  end if
  if hasIndex(gco,"packRootShell") then gco.packRootShell=null
  code="get_custom_object[""packRootShell""]=get_shell("""+cred.user+""","""+cred.pass+""")"
  comp.touch(home,".x_x.src")
  f=comp.File(home+"/.x_x.src")
  if not f then return _pe("Failed to create build file")
  f.set_content(code)
  prt("Building su payload...")
  r=ex.build(f.path,home)
  if r!="" then
    _pe(_bf+r)
    qrm(comp,f)
    return null
  end if
  ex.launch(home+"/.x_x")
  f=comp.File(home+"/.x_x.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_x")
  if f then qrm(comp,f)
  if gco.hasIndex("packRootShell") and _to(gco.packRootShell)==_sh then
    s=gco.packRootShell
    _ps("Got "+cred.user+" shell!")
    return s
  end if
  _pe("su failed — wrong password?")
  return null
end function
_grM=function(shell)
  comp=_HC(shell)
  lip=comp.local_ip
  pip=comp.public_ip
  if not lip and not pip then return null
  mk=pip+":"+lip
  if gco.hasIndex("metas") and gco.metas.hasIndex(mk) and gco.metas[mk] then return gco.metas[mk]
  if not lip then lip=pip
  u=_gu(shell)
  home=_hd(u)
  prt("Uploading metaxploit.so...")
  _c=_cur
  r=scp(_c.shell,_c.metaxPath,home,shell)
  if r isa string then return _pe("SCP failed: "+r)
  if gco.hasIndex("meta_local") then gco.meta_local=null
  if gco.hasIndex("router_local") then gco.router_local=null
  code="m=include_lib("""+home+"/metaxploit.so"");if not m or typeof(m)!=""MetaxploitLib"" then;_g=function;p=File(host_computer(get_shell),""/"");d=get_folders(p)+get_files(p);while len(d);f=pull(d);if is_folder(f) then d=d+get_folders(f)+get_files(f);if name(f)==""metaxploit.so"" or name(f)=="".metaxploit.so"" then;l=include_lib(path(f));if l and typeof(l)==""MetaxploitLib"" then return l;end if;end while;end function;m=_g;end if;if m then get_custom_object[""meta_local""]=m;c=host_computer(get_shell);if c.public_ip and c.public_ip!=""0.0.0.0"" then get_custom_object[""router_local""]=get_router"
  comp.touch(home,".x_m.src")
  f=comp.File(home+"/.x_m.src")
  if not f then
    f=comp.File(home+_mx)
    if f then qrm(comp,f)
    return _pe("Failed to create loader")
  end if
  f.set_content(code)
  prt("Building loader...")
  r=shell.build(f.path,home)
  if r!="" then
    f=comp.File(home+"/.x_m.src")
    if f then qrm(comp,f)
    f=comp.File(home+_mx)
    if f then qrm(comp,f)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_m")
  f=comp.File(home+"/.x_m.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_m")
  if f then qrm(comp,f)
  if not gco.hasIndex("meta_local") or not gco.meta_local then
    f=comp.File(home+_mx)
    if f then qrm(comp,f)
    return _pe("Failed to load metaxploit")
  end if
  rMetax=gco.meta_local
  rRouter=null
  if gco.hasIndex("router_local") and gco.router_local then rRouter=gco.router_local
  f=comp.File(home+_mx)
  if f then qrm(comp,f)
  gco.metas[mk]=rMetax
  if rRouter then gco.routers[mk]=rRouter
  _ps("Cached metaxploit for "+mk)
  return rMetax
end function
_rlov=function(shell,libPath,addr,val,extra)
  comp=_HC(shell);u=_gu(shell);home=_hd(u);_c=_cur
  if not _c.metaxPath then return null
  mx=home+"/metaxploit.so"
  r=scp(_c.shell,_c.metaxPath,home,shell)
  if r isa string then return null
  gco.lo_result="__none";eStr=""
  if extra then eStr=","""+extra+""""
  code="m=include_lib("""+mx+""");if m then;l=m.load("""+libPath+""");if l then;get_custom_object[""lo_result""]=l.overflow("""+addr+""","""+val+""""+eStr+");end if;end if"
  comp.touch(home,".x_ov.src");f=comp.File(home+"/.x_ov.src")
  if not f then
    mf=comp.File(mx);if mf then qrm(comp,mf)
    return null
  end if
  f.set_content(code);r=shell.build(f.path,home)
  sf=comp.File(home+"/.x_ov.src");if sf then qrm(comp,sf)
  if r!="" then
    bf=comp.File(home+"/.x_ov");if bf then qrm(comp,bf)
    mf=comp.File(mx);if mf then qrm(comp,mf)
    return null
  end if
  shell.launch(home+"/.x_ov")
  bf=comp.File(home+"/.x_ov");if bf then qrm(comp,bf)
  mf=comp.File(mx);if mf then qrm(comp,mf)
  res=gco.lo_result;gco.lo_result=null
  if res=="__none" then return null
  return res
end function
localScan=function(remoteShell)
  comp=_HC(remoteShell)
  isRemote=comp.public_ip!=gco.home.ip
  lip=comp.local_ip
  if not lip then lip=comp.public_ip
  if not lip then return _pe("Cannot determine IP for this shell")
  if remoteShell==_ls then rMetax=_scn.metax else rMetax=_grM(remoteShell)
  if not rMetax then return
  remoteIP=comp.public_ip
  _ps("Scanning local libraries on "+lip)
  _p ""
  libDir=File(comp,"/lib")
  if not libDir then return _pe("Cannot access /lib")
  libFiles=get_files(libDir)
  if not libFiles then return prt("No library files found in /lib")
  libList=[]
  for lf in libFiles;if name(lf)=="metaxploit.so" then continue;libList.push(lf);end for
  if not libList then return prt("No scannable libraries found")
  lTargets=[]
  while true
    if gco.H then break
    _p ""
    _p LG("Local Scan: "+lip)
    _p ""
    _p GY(_lj("#",5))+GY(_lj("LIBRARY",30))+GY("PATH")
    for lf in libList;i=__lf_idx+1;_p WH(_lj(_s(i),5))+YL(_lj(lf.name,30))+GY(lf.path);end for
    if lTargets then
      prt("Previously scanned:")
      for tgt in lTargets
        i=__tgt_idx+1
        t=PR("[")+WH(_s(i))+PR("] ")+YL("• ")+OR(tgt.ln)+WH(" (Version: "+tgt.ver+") ")
        _p t
        _p "    "+GN(_s(tgt.total))+WH(" exploits")
      end for
    end if
    _p ""
    if libList.len==1 and not lTargets then
      prt("Single library, auto-scanning...")
      c="a"
    else
      c=_uig("[Lib #, 'a' scan all, 'b' back, '?' help] > ")
    end if
    if not c or _tl(c)=="b" then break
    if c.trim=="?" then
      _showHelp
      continue
    end if
    scanLibs=[]
    if _tl(c)=="a" then
      scanLibs=libList
    else
      sel=_ti(c.trim)
      if not sel isa number or sel<1 or sel>libList.len then
        _pe(_iv)
        continue
      end if
      scanLibs.push(libList[sel-1])
    end if
    newLibs=[]
    for lf in scanLibs
      already=false
      for tgt in lTargets;if tgt.ln==lf.name then;already=true;break;end if;end for
      if not already then newLibs.push(lf)
    end for
    if not newLibs then
      ans=_ui(YL("[!] Already scanned. Rescan? (y/N) "))
      if ans and _tl(ans)=="y" then newLibs=scanLibs
    end if
    if newLibs then
      prt("Scanning "+_s(newLibs.len)+" libraries...")
      _p ""
      hMetax=_scn.metax
      for lf in newLibs
        if isRemote then
          if lf.name=="kernel_router.so" then
            ses=rMetax.net_use(lip,0);if not ses then continue;lib=ses.dump_lib
          else
            lib=rMetax.load(lf.path)
          end if
        else
          lib=hMetax.load(lf.path)
        end if
        if not lib then continue
        ln=lib.lib_name
        ver=lib.version
        addresses=hMetax.scan(lib)
        if not addresses then continue
        exploits=[]
        for addr in addresses
          vulnInfo=hMetax.scan_address(lib,addr)
          if not vulnInfo then continue
          for line in vulnInfo.split(char(10))
            if line.indexOf(_uc)==0 then
              s=line.indexOf("<b>")+3
              d=line.indexOf("</b>")
              if s>2 and d!=null then
                unsecured=line[s:d]
                exploits.push({"addr":addr,"val":unsecured})
              end if
            end if
          end for
        end for
        if not exploits then continue
        p=lib.is_patched(1)
        if p isa string then
          patchStr=GN("Patched To: "+p)
        else if p==1 then
          patchStr=GN("Patched")
        else
          patchStr=RD("Not Patched")
        end if
        ct={"shells":0,"computers":0,"files":0,"bounces":0,"unknown":0}
        classified=[]
        for e in exploits
          if isRemote then
            r=[_uk,""]
          else
            ex=lib.overflow(e.addr,e.val)
            r=_classifyEx(ex,ln)
          end if
          if r[0]==_sh then
            ct.shells=ct.shells+1
          else if r[0]==_cm then
            ct.computers=ct.computers+1
          else if r[0]=="file" then
            ct.files=ct.files+1
          else if r[0]=="bounce" then
            ct.bounces=ct.bounces+1
          else
            ct.unknown=ct.unknown+1
          end if
          classified.push({"addr":e.addr,"val":e.val,"type":r[0],"user":r[1]})
        end for
        lTargets.push({"lib":lib,"ln":ln,"ver":ver,"exploits":classified,"patchStr":patchStr,"total":classified.len,"ct":ct,"libPath":lf.path})
      end for
    end if
    if not lTargets then
      prt("No exploitable libraries found")
      if libList.len==1 then break
      continue
    end if
    while true
      if gco.H then break
      _p ""
      _p LG("Local Scan: "+lip)
      prt("Exploitable libraries:")
      for tgt in lTargets
        i=__tgt_idx+1
        t=PR("[")+WH(_s(i))+PR("] ")+YL("• ")+OR(tgt.ln)+WH(" (Version: "+tgt.ver+") ")
        _p t
        _p GN("    |-> ")+tgt.patchStr
        _p "    "+GN(_s(tgt.total))+WH(" exploits found")
        _p "    Sh:"+GN(_s(tgt.ct.shells))+" Co:"+YL(_s(tgt.ct.computers))+" Fi:"+RD(_s(tgt.ct.files))+" Bo:"+PR(_s(tgt.ct.bounces))+" Un:"+GY(_s(tgt.ct.unknown))
      end for
      c=_uig("[Target #, 'b' back, '?' help, home] > ")
      if not c then continue
      if _tl(c)=="b" then break
      if c.trim=="?" then
        _showHelp
        continue
      end if
      sel=_ti(c.trim)
      if not sel isa number or sel<1 or sel>lTargets.len then
        _pe(_iv)
        continue
      end if
      tgt=lTargets[sel-1]
      while true
        if gco.H then break
        _p ""
        _p GY(_lj("#",5))+GY(_lj("TYPE",12))+GY(_lj("USER",12))+GY(_lj("ADDRESS",14))+GY("VALUE")
        for e in tgt.exploits
          e.i=__e_idx+1
          _p _exTag(e)
        end for
        c2=_uig("[Exploit #, 'c' custom, 'ba' bounce all, 'b' back, '?' help, home] > ")
        if not c2 then continue
        if _tl(c2)=="b" then break
        if c2.trim=="?" then
          _showHelp
          continue
        end if
        if _tl(c2)=="c" then
          ca=_uig("[Memory address] > ")
          if not ca or not ca.trim.len then continue
          cv=_uig("[Unsafe check value] > ")
          if not cv or not cv.trim.len then continue
          if isRemote then ex=_rlov(remoteShell,tgt.libPath,ca.trim,cv.trim) else ex=tgt.lib.overflow(ca.trim,cv.trim)
          _exR(ex)
          continue
        end if
        if _tl(c2)=="ba" then
          bip=_ui(OR("[Bounce target IP] > "))
          if not bip or not _vi(bip.trim) then
            _pe(_iip)
            continue
          end if
          bip=bip.trim
          for ne in tgt.exploits
            if ne.type!="null" then continue
            prt("Trying "+ne.addr+" "+ne.val+" -> "+bip)
            if isRemote then ex=_rlov(remoteShell,tgt.libPath,ne.addr,ne.val,bip) else ex=tgt.lib.overflow(ne.addr,ne.val,bip)
            if not ex then
              _p GY("    null")
              continue
            end if
            if ex isa string then
              _p GY("    "+ex)
              continue
            end if
            _exR(ex)
          end for
          continue
        end if
        esel=_ti(c2.trim)
        if not esel isa number or esel<1 or esel>tgt.exploits.len then
          _pe(_iv)
          continue
        end if
        exploit=tgt.exploits[esel-1]
        gco.meta_local=null
        if isRemote then ex=_rlov(remoteShell,tgt.libPath,exploit.addr,exploit.val) else ex=tgt.lib.overflow(exploit.addr,exploit.val)
        if not ex then
          _p GY(_en)
          ans=_uig("[Password or bounce IP, or 'b' to skip] > ")
          if not ans or _tl(ans)=="b" then continue
          if isRemote then ex=_rlov(remoteShell,tgt.libPath,exploit.addr,exploit.val,ans.trim) else ex=tgt.lib.overflow(exploit.addr,exploit.val,ans.trim)
          if not ex then
            prt("Exploit returned null again")
            continue
          else if ex isa string then
            _pe(ex)
            continue
          end if
          obj=_to(ex)
          if obj==_cm then
            _ps("Got computer (bounce)!")
            _p OR(_uu)+WH(_gu(ex))
            _p OR(_uh)+WH(ex.public_ip)
            _exM(ex,_cm)
          else
            _ps("Password change may have succeeded!")
          end if
          continue
        end if
        _exR(ex)
      end while
    end while
  end while
end function
_grabAccounts=function(ex)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  entries=[]
  for f in getAllFiles(root)
    if f.is_folder then continue
    n=f.name
    if n!="Mail.txt" and n!="Bank.txt" then continue
    if not _hp(f,"r") then
      entries.push({"type":n.replace(".txt",""),"user":f.path,"acct":"[no read]","hash":"","path":f.path})
      continue
    end if
    content=_gc(f)
    if not content then continue
    for line in content.split(char(10))
      if not line then continue
      parts=line.split(":")
      if parts.len<2 then continue
      tag="Email"
      if n=="Bank.txt" then tag="Bank"
      pp=f.path.split("/")
      usr="?"
      for pi in range(0,pp.len)
        if pp[pi]=="home" and pi+1<pp.len then
          usr=pp[pi+1]
          break
        end if
      end for
      entries.push({"type":tag,"user":usr,"acct":parts[0],"hash":parts[1],"path":f.path})
    end for
  end for
  if not entries then return prt("No email or bank accounts found")
  _p OR("--- Email & Bank Accounts ---")
  _p GY(_lj("#",5))+GY(_lj("TYPE",8))+GY(_lj("USER",14))+GY(_lj("ACCOUNT",28))+GY("HASH")
  for e in entries;i=__e_idx+1;if e.type=="Email" then tClr=YL(_lj(e.type,8)) else tClr=GN(_lj(e.type,8));_p WH(_lj(_s(i),5))+tClr+WH(_lj(e.user,14))+BL(_lj(e.acct,28))+GY(e.hash);end for
  if not crypto then return _pw("crypto not loaded — cannot crack")
  cracked=[]
  _p ""
  _p GY("  Enter # to crack, 'a' for all, or 'b' to skip")
  while true
    if gco.H then return cracked
    ans=_uig("[Crack #/a/b] > ")
    if not ans or _tl(ans)=="b" then return cracked
    if _tl(ans)=="a" then
      for e in entries
        if not e.hash or not e.hash.len then continue
        _p YL("["+_s(__e_idx+1)+"/"+_s(entries.len)+"] ")+GY("Cracking "+e.type+" "+e.acct+"...")
        pass=decipher(crypto,e.hash)
        if not pass then
          _p WH(_lj(e.acct,28))+RD("failed")
        else
          _p WH(_lj(e.acct,28))+GN(pass)
          cracked.push({"type":e.type,"user":e.user,"acct":e.acct,"pass":pass})
        end if
      end for
      return cracked
    end if
    sel=_ti(ans.trim)
    if not sel isa number or sel<1 or sel>entries.len then
      _pe(_iv)
      continue
    end if
    e=entries[sel-1]
    if not e.hash or not e.hash.len then
      _pe("No hash to crack")
      continue
    end if
    prt("Cracking "+e.type+" "+e.acct+"...")
    pass=crypto.decipher(e.hash)
    if not pass then
      _p WH(_lj(e.acct,28))+RD("failed")
    else
      _p WH(_lj(e.acct,28))+GN(pass)
      cracked.push({"type":e.type,"user":e.user,"acct":e.acct,"pass":pass})
    end if
  end while
end function
_szU=["B","KB","MB","GB","TB"]
_fmtSz=function(f)
  b=val(size(f))
  i=0
  while b>1024;b=b/1024;i=i+1;end while
  return _s(round(b,2))+_szU[i]
end function
_fmtP=function(p)
  o=""
  for c in p
    if c=="r" then
      o=o+GN(c)
    else if c=="w" then
      o=o+OR(c)
    else if c=="x" then
      o=o+RD(c)
    else
      o=o+GY(c)
    end if
  end for
  return o
end function
_tree=function(ex)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  all=getAllFiles(root)
  _p OR(_hb("File Tree"))
  _p GY(_lj("PERMS",12))+GY(_lj("OWNER",16))+GY(_lj("GROUP",16))+GY(_lj("SIZE",10))+GY("PATH")
  dirs=0
  fls=0
  for f in all
    p=_fmtP(f.permissions)
    o=f.owner
    g=f.group
    if f.is_folder then
      sz="-"
      n=BL(f.path+"/")
      dirs=dirs+1
    else
      sz=_fmtSz(f)
      n=WH(f.path)
      fls=fls+1
    end if
    _p _fmtP(_lj(f.permissions,12))+GY(_lj(o,16))+GY(_lj(g,16))+YL(_lj(sz,10))+n
  end for
  _p ""
  _p GY(_s(dirs)+" directories, "+_s(fls)+" files, "+_s(all.len)+" total")
end function
browseFiles=function(ex,u=null)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  cur=root
  if u then
    hp=_hd(u)
    hf=null
    obj=_to(ex)
    if obj==_cm then
      hf=ex.File(hp)
    else if indexOf(obj,_sh)!=null then
      hf=_HC(ex).File(hp)
    end if
    if hf then cur=hf
  end if
  interesting=["Bank.txt","Mail.txt","Browser.txt","passwd","shadow","system.log",".key","authorized_keys","FileExplorer.exe"]
  while true
    if gco.H then break
    _p OR("--- ")+YL(cur.path)+OR(" ---")
    folders=cur.get_folders
    files=cur.get_files
    items=[]
    if folders then
      for f in folders;items.push({"obj":f,"isDir":true});end for
    end if
    if files then
      for f in files;items.push({"obj":f,"isDir":false});end for
    end if
    if not items then
      _p GY("  (empty)")
    else
      _p GY(_lj("#",5))+GY(_lj("PERMS",12))+GY(_lj("OWNER",16))+GY(_lj("GROUP",16))+GY(_lj("SIZE",10))+GY("NAME")
      for it in items
        idx=__it_idx+1
        f=it.obj
        p=f.permissions
        o=f.owner
        g=f.group
        sz="-"
        if not it.isDir then sz=_fmtSz(f)
        n=f.name
        isInteresting=false;
        for iName in interesting;if n.indexOf(iName)!=null then;isInteresting=true;break;end if;end for
        if it.isDir then
          nTag=BL(n+"/")
        else if isInteresting then
          nTag=YL(n)+RD(" *")
        else
          nTag=WH(n)
        end if
        _p WH(_lj(_s(idx),5))+_fmtP(_lj(p,12))+GY(_lj(o,16))+GY(_lj(g,16))+GY(_lj(sz,10))+nTag
      end for
    end if
    c=_uig("[# to enter/cat, path, 'b' up, 'x' exit] > ")
    if _tl(c)=="x" then return
    if not c or not c.trim.len or _tl(c)=="b" then
      p=cur.parent
      if p then cur=p
      continue
    end if
    sel=_ti(c.trim)
    if sel isa number and sel>=1 and sel<=items.len then
      it=items[sel-1]
      if it.isDir then
        cur=it.obj
      else
        if not _hp(it.obj,"r") then
          _pe("No read permission")
          continue
        end if
        content=_gc(it.obj)
        if not content then
          prt("File is empty or binary")
        else
          _p OR("--- ")+WH(it.obj.name)+OR(" ---")
          _p content
        end if
      end if
    else
      target=null
      for f in getAllFiles(toRoot(ex));if f.path==c.trim then;target=f;break;end if;end for
      if not target then
        rr=toRoot(ex)
        parts=c.trim.split("/")
        nav=rr
        ok=true
        for p in parts
          if not p or not p.len then continue
          found=false
          for d in nav.get_folders;if d.name==p then;nav=d;found=true;break;end if;end for
          if not found then
            ok=false
            break
          end if
        end for
        if ok and nav!=rr then cur=nav else _pe("Not found: "+c.trim)
      else
        if target.is_folder then
          cur=target
        else
          if not _hp(target,"r") then
            _pe("No read permission")
          else
            content=_gc(target)
            if not content then return prt("File is empty or binary")
            _p OR("--- ")+WH(target.name)+OR(" ---")
            _p content
          end if
        end if
      end if
    end if
  end while
end function
downloadFile=function(ex)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  lShell=gco.home.shell
  isPv=_cur!=gco.home
  if isPv then
    ch=_uig("[Download to: m=main, p=pivot] > ")
    if ch and _tl(ch)=="p" then lShell=_cur.shell
  end if
  lComp=_HC(lShell)
  lUser=_gu(lShell)
  lHome=_hd(lUser)
  _p ""
  _p GY("  Enter remote file path to download")
  _p GY("  Files saved to ")+YL(lHome+"/Downloads/")
  p=_uig("[remote path, or 'b'] > ")
  if not p or _tl(p)=="b" then return
  p=p.trim
  target=null
  for f in getAllFiles(root);if f.path==p then;target=f;break;end if;end for
  if not target then return _pe("File not found: "+p)
  if target.is_folder then return _pe("Cannot download a folder")
  if not _hp(target,"r") then return _pe("No read permission")
  dlDir=lComp.File(lHome+"/Downloads")
  if not dlDir then
    r=lComp.create_folder(lHome,"Downloads")
    if r isa string then return _pe(r)
  end if
  if _to(ex).indexOf(_sh)!=null then
    r=ex.scp(p,lHome+"/Downloads",lShell)
    if r isa string then return _pe("SCP failed: "+r)
    _ps("Downloaded "+target.name+" -> "+lHome+"/Downloads/"+target.name)
  else
    content=_gc(target)
    if content==null then return _pe("Cannot read file (binary, need shell for scp)")
    fn=target.name
    existing=lComp.File(lHome+"/Downloads/"+fn)
    if existing then fn=fn+"_"+_s(floor(rnd*9999))
    r=lComp.touch(lHome+"/Downloads",fn)
    if r isa string then return _pe(r)
    df=lComp.File(lHome+"/Downloads/"+fn)
    if not df then return _pe("Failed to create local file")
    set_content(df,content)
    _ps("Downloaded "+target.name+" -> "+lHome+"/Downloads/"+fn)
  end if
end function
uploadFile=function(ex)
  if _to(ex).indexOf(_sh)==null then return _pe(_ns+" to upload files")
  lShell=gco.home.shell
  isPv=_cur!=gco.home
  if isPv then
    ch=_uig("[Upload from: m=main, p=pivot] > ")
    if ch and _tl(ch)=="p" then lShell=_cur.shell
  end if
  lComp=_HC(lShell)
  comp=_HC(ex)
  u=_gu(ex)
  rHome=_hd(u)
  _p ""
  _p GY("  Enter local file path to upload")
  lp=_uig("[local path, or 'b'] > ")
  if not lp or _tl(lp)=="b" then return
  src=lComp.File(lp.trim)
  if not src then return _pe("Local file not found: "+lp.trim)
  if src.is_folder then return _pe("Cannot upload a folder")
  _p GY("  Destination dir (default: ")+YL(rHome)+GY(")")
  dest=_uig("[remote dir, or enter for default] > ")
  if not dest or not len(dest.trim) then dest=rHome else dest=dest.trim
  r=lShell.scp(src.path,dest,ex)
  if r isa string then return _pe("SCP failed: "+r)
  _ps("Uploaded "+src.name+" -> "+dest+"/"+src.name)
end function
renameFile=function(ex)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  _p ""
  _p GY("  Enter path of file/folder to rename")
  p=_uig("[path, or 'b'] > ")
  if not p or _tl(p)=="b" then return
  target=null
  for f in getAllFiles(root);if f.path==p.trim then;target=f;break;end if;end for
  if not target then return _pe("Not found: "+p.trim)
  if not _hp(target,"w") then return _pe("No write permission")
  _p GY("  Current name: ")+WH(target.name)
  nn=_uig("[new name, or 'b'] > ")
  if not nn or _tl(nn)=="b" then return
  r=target.rename(nn.trim)
  if r=="" then _pe("Renamed -> "+nn.trim,"s") else prt(_s(r))
end function
installRshellServer=function(shell)
  comp=_HC(shell)
  u=_gu(shell)
  if u!="root" then return _pe("Need root shell to install rshell server")
  procs=comp.show_procs
  if indexOf(procs,"rshell")!=null then return _pw("rshell service appears to be running already")
  rsFile=comp.File(_lr)
  if rsFile then
    rsLib=include_lib(_lr)
    if rsLib then
      r=rsLib.install_service
      if r!=true and r isa string then return _pe(r)
      return _ps("rshell server installed!")
    end if
  end if
  hComp=_HC(gco.home.shell)
  rshellPath=null
  rsFile=hComp.File(_lr)
  if rsFile then
    rshellPath=_lr
  else
    rsFile=hComp.File(current_path+_rs)
    if rsFile then
      rshellPath=current_path+_rs
    else
      _pp=split(current_path,"/")
      _pp.pop
      _pPath=join(_pp,"/")
      if not _pPath then _pPath="/"
      rsFile=hComp.File(_pPath+_rs)
      if rsFile then rshellPath=_pPath+_rs
    end if
  end if
  if not rshellPath then return _pe("librshell.so not found on home (/lib/ or current dir)")
  home="/root"
  prt("Uploading librshell.so...")
  r=gco.home.shell.scp(rshellPath,home,shell)
  if r isa string then return _pe("SCP failed: "+r)
  code="a=include_lib("""+home+"/librshell.so"");if not a then exit(""Error: librshell.so not found"");c=install_service(a);if c!=true then exit(c);print(""rshell server installed"")"
  comp.touch(home,".x_rs.src")
  f=comp.File(home+"/.x_rs.src")
  if not f then
    f=comp.File(home+_rs)
    if f then qrm(comp,f)
    return _pe("Failed to create installer")
  end if
  f.set_content(code)
  prt("Installing rshell server...")
  r=build(shell,path(f),home)
  if r!="" then
    f=comp.File(home+"/.x_rs.src")
    if f then qrm(comp,f)
    f=comp.File(home+_rs)
    if f then qrm(comp,f)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_rs")
  f=comp.File(home+"/.x_rs.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_rs")
  if f then qrm(comp,f)
  f=comp.File(home+_rs)
  if f then qrm(comp,f)
  _ps("rshell server installed!")
  pip=comp.public_ip
  if not pip then return
  importRshellServer(pip,shell)
end function
startRshellClient=function(shell)
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  hdir=comp.File(home)
  if not hdir or not _hp(hdir,"w") then
    home="/tmp"
    hdir=comp.File(home)
    if not hdir or not _hp(hdir,"w") then return _pe("No writable directory found")
  end if
  myIP=_uig("[Your rshell server IP] > ")
  if not myIP or not _vi(myIP.trim) then return _pe(_iip)
  myIP=myIP.trim
  port=_uig("[Port (default 1222)] > ")
  if not port or not len(port.trim) then port="1222"
  port=port.trim
  procName=_uig("[Process name (default ps)] > ")
  if not procName or not len(procName.trim) then procName="ps"
  procName=procName.trim
  code="_g=function;p=File(host_computer(get_shell),""/"");d=get_folders(p)+get_files(p);while len(d);f=pull(d);if is_folder(f) then d=d+get_folders(f)+get_files(f);if name(f)==""metaxploit.so"" or name(f)=="".metaxploit.so"" then;l=include_lib(path(f));if l and typeof(l)==""MetaxploitLib"" then return l;end if;end while;end function;m=_g;if m then rshell_client(m,"""+myIP+""","+port+","""+procName+""")"
  comp.touch(home,".x_rc.src")
  f=comp.File(home+"/.x_rc.src")
  if not f then return _pe("Failed to create rshell client")
  f.set_content(code)
  prt("Building rshell client...")
  r=build(shell,path(f),home)
  if r!="" then
    f=comp.File(home+"/.x_rc.src")
    if f then qrm(comp,f)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_rc")
  f=comp.File(home+"/.x_rc.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_rc")
  if f then qrm(comp,f)
  _ps("rshell client launched as '"+procName+"' -> "+myIP+":"+port)
end function
importRshellServer=function(ip,remoteShell=null)
  if hasIndex(gco.rshell_servers,ip) then return _pw(ip+" is already imported")
  prt("Importing rshell server "+ip+"...")
  if remoteShell then
    rMetax=_grM(remoteShell)
    if not rMetax then return _pe("Cannot get metaxploit on remote")
  else
    if not metax then return _pe("metaxploit.so not loaded")
    rMetax=metax
  end if
  shells=rMetax.rshell_server
  if shells isa list then
    gco.rshell_servers[ip]=rMetax
  else if shells==null or shells==false then
    gco.rshell_servers[ip]=rMetax
    shells=[]
  else
    return _pe(_s(shells))
  end if
  if shells isa list and shells then
    for s in shells;gco.rshell_shells.push(s);end for
    _ps("Imported "+ip+" — "+_s(shells.len)+" shell(s)")
  else
    _ps("Imported "+ip+" — 0 shells (waiting for connections)")
  end if
end function
refreshRshellShells=function
  if not gco.rshell_servers then return _pe("No rshell servers imported")
  gco.rshell_shells=[]
  for srv in gco.rshell_servers;shells=rshell_server(srv.value);if not shells isa list then continue;for s in shells;gco.rshell_shells.push(s);end for;end for
  _ps("Refreshed: "+_s(gco.rshell_shells.len)+" shell(s) from "+_s(gco.rshell_servers.len)+" server(s)")
end function
rshellMenu=function(shell=null)
  if not metax then return _pe("metaxploit.so not loaded")
  while true
    if gco.H then break
    srvCount=gco.rshell_servers.len
    shellCount=gco.rshell_shells.len
    _p ""
    _p LG("RShell Manager")
    _p GY("  Servers: ")+GN(_s(srvCount))+GY("  Shells: ")+GN(_s(shellCount))
    _p ""
    if gco.rshell_servers then
      _p GY("  Imported servers:")
      idx=0
      for srv in gco.rshell_servers;_p WH("    "+_lj(_s(idx+1),4))+YL(srv.key);idx=idx+1;end for
    end if
    if gco.rshell_shells then
      _p ""
      _p GY("  Connected shells:")
      for s in gco.rshell_shells
        i=__s_idx+1
        sComp=_HC(s)
        u=_gu(s)
        pip=sComp.public_ip
        lip=sComp.local_ip
        _p WH("    "+_lj(_s(i),4))+GN(_lj(u,15))+YL(pip)+GY(":")+BL(lip)
      end for
    end if
    if shell then _p _mi("s","  Install rshell server")
    if shell then _p _mi("c","  Start rshell client")
    _p _mi("i","  Import server by IP")
    _p _mi("r","  Refresh shells")
    if shellCount then _p _mi("#","  Open shell by number")
    _p _bk
    ans=_uig("[rshell] > ")
    if not ans or _tl(ans)=="b" then break
    _ra=_tl(ans)
    if _ra=="s" and shell then
      installRshellServer(shell)
    else if _ra=="c" and shell then
      startRshellClient(shell)
    else if _ra=="i" then
      defIP=null
      if shell then defIP=_HC(shell).public_ip
      prompt="[Server IP to import"
      if defIP then prompt=prompt+" (default "+defIP+")" else prompt=prompt+" (default local)"
      prompt=prompt+"] > "
      ip=_uig(prompt)
      if not ip or not len(ip.trim) then
        if defIP then importRshellServer(defIP,shell) else importRshellServer(_HC(get_shell).public_ip)
      else
        ip=ip.trim
        if _vi(ip) then importRshellServer(ip,shell) else _pe(_iip)
      end if
    else if _ra=="r" then
      refreshRshellShells
    else
      sel=_ti(ans.trim)
      if not sel isa number or sel<1 or sel>gco.rshell_shells.len then
        _pe(_iv)
      else
        s=gco.rshell_shells[sel-1]
        _ps("Opening shell...")
        _p OR(_uu)+WH(_gu(s))
        _p OR(_uh)+WH(_HC(s).public_ip)
        _exM(s,_sh)
      end if
    end if
  end while
end function
_pivotMenu=function
  pv=gco.pivots
  while true
    if gco.H then break
    prt("Pivot Sessions")
    _p GY("  Home: ")+YL(gco.home.ip)+GY(":")+YL(gco.home.lip)
    if not pv or pv.len==0 then
      _p GY("  No active pivots")
    else
      i=0
      _len=pv.len
      while i<_len
        n=pv[i]
        idx=_s(i+1)
        _p GN("  ["+idx+"] ")+YL(n.ip)+GY(":")+YL(n.lip)+GY(" metax:")+cbool(n.metax)+GY(" crypto:")+cbool(n.crypto)
        i=i+1
      end while
    end if
    _p _mi("x","  Kill all pivot sessions")
    _p _bk
    c=_uig("[pivots] > ")
    if not c or _tl(c)=="b" then return
    if _tl(c)=="x" then
      if not pv or pv.len==0 then
        _pw("No pivots to kill")
        continue
      end if
      ans=_ui(YL("[!] Kill all "+_s(pv.len)+" pivot sessions? (y/N) "))
      if ans and _tl(ans)=="y" then
        while pv.len>0;pv.pop;end while
        _ps("All pivot sessions cleared")
      end if
    end if
  end while
end function
_pivotScanner=function(shell)
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  hdir=comp.File(home)
  if not hdir or not _hp(hdir,"w") then
    home="/tmp"
    hdir=comp.File(home)
    if not hdir or not _hp(hdir,"w") then return _pe("No writable directory on remote")
  end if
  pip=comp.public_ip
  lip=comp.local_ip
  parts=_selfPath.split("/")
  binName=parts[parts.len-1]
  payDir=home+"/payload"
  prt("Pivoting "+binName+" to "+pip+" ("+lip+")")
  pf=comp.File(payDir)
  if not pf then comp.create_folder(home,"payload")
  pf=comp.File(payDir)
  if not pf then return _pe("Failed to create payload folder")
  prt("Uploading "+binName+"...")
  _c=_cur
  r=_c.shell.scp(_selfPath,payDir,shell)
  if r isa string then return _pe("SCP upload binary failed: "+r)
  hmPath=_c.metaxPath
  hShell=_c.shell
  hComp=_HC(hShell)
  if hmPath then
    prt("Uploading metaxploit.so...")
    r=hShell.scp(hmPath,payDir,shell)
    if r isa string then _pw("metaxploit.so upload failed: "+r)
  end if
  cPath=null
  if hComp.File("/lib/crypto.so") then cPath="/lib/crypto.so"
  if not cPath and hComp.File(current_path+"/crypto.so") then cPath=current_path+"/crypto.so"
  if cPath then
    prt("Uploading crypto.so...")
    r=hShell.scp(cPath,payDir,shell)
    if r isa string then _pw("crypto.so upload failed: "+r)
  end if
  rsPath=null
  if hComp.File(_lr) then rsPath=_lr
  if not rsPath and hComp.File(current_path+_rs) then rsPath=current_path+_rs
  if rsPath then
    prt("Uploading librshell.so...")
    r=hShell.scp(rsPath,payDir,shell)
    if r isa string then _pw("librshell.so upload failed: "+r)
  end if
  _ps("Launching "+binName+" on "+pip+"...")
  _p GY("  Type 'x' in the main menu to return to parent session")
  _p ""
  shell.launch(payDir+"/"+binName,"pivot")
  pf=comp.File(payDir)
  if pf then qrm(comp,pf)
  if gco.hasIndex("pivots") then
    pv=gco.pivots
    if pv and pv.len>0 then pv.pop
  end if
  _ps("Returned from pivot on "+pip)
end function
_echo=function(raw,c)
  ap=raw.indexOf(">>")
  ow=raw.indexOf(">")
  if ap!=null then
    t=raw[:ap].trim;fp=raw[ap+2:].trim
    if fp.indexOf("/")!=0 then fp=_hd(_gu(c))+"/"+fp
    f=c.File(fp)
    if not f then return _pe("Not found: "+fp)
    f.set_content(_gc(f)+char(10)+t);_ps("Appended to "+fp)
  else if ow!=null then
    t=raw[:ow].trim;fp=raw[ow+1:].trim
    if fp.indexOf("/")!=0 then fp=_hd(_gu(c))+"/"+fp
    ps=fp.split("/");fn=ps[-1];dr=ps[:-1].join("/")
    if not dr then dr="/"
    f=c.File(fp)
    if f then f.set_content(t) else c.touch(dr,fn);f=c.File(fp);if f then f.set_content(t) else return _pe("Cannot create "+fp)
    _ps("Wrote "+fp)
  else
    _p WH(raw)
  end if
end function
_deploy=function(shell)
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  hShell=gco.home.shell
  hComp=_HC(hShell)
  hu=_gu(hShell)
  hHome=_hd(hu)
  bn=_uig("[bin name or path, 'b' cancel] > ")
  if not bn or _tl(bn)=="b" then return
  bn=bn.trim
  if bn.indexOf("/")!=null then
    sp=bn
  else
    sp=hHome+"/Downloads/"+bn
    if not hComp.File(sp) then
      _pw(sp+" not found")
      sp=_uig("[full path on main] > ")
      if not sp or _tl(sp)=="b" then return
      sp=sp.trim
    end if
  end if
  sf=hComp.File(sp)
  if not sf then return _pe("Not found: "+sp)
  prt("Uploading "+sf.name+"...")
  r=hShell.scp(sp,home,shell)
  if r isa string then return _pe("SCP failed: "+r)
  _ps("Launching "+sf.name+"...")
  shell.launch(home+"/"+sf.name)
  _ps("Deployed "+sf.name)
end function
_exM=function(ex,exType)
  shell=null
  if exType==_sh then shell=ex
  _comp=null
  _cip=[]
  u=null
  cm={}
  cm.c=function
    passwd=getFileEx(ex,"/etc/passwd")
    if passwd then
      _p OR("--- /etc/passwd ---")
      creds=_ppw(passwd)
      _cip2=null
      if gco.hasIndex("_eip") then _cip2=gco._eip
      if shell then _cip2=_HC(shell).local_ip
      for cr in creds;_acr2(_cip2,cr.user,cr.pass);end for
    else
      prt("Cannot read /etc/passwd")
    end if
  end function
  cm.s=function
    if _cip.len and _gu(ex)!="root" then
      newShell=connectAs(_cip,ex)
      if newShell then
        outer.ex=newShell
        outer.shell=newShell
        _p OR(_uu)+WH(_gu(ex))
        _p OR(_uh)+WH(_HC(ex).public_ip)
      end if
    else
      prt("No creds or already root")
    end if
  end function
  cm.a=function
    if not shell then return prt(_ns+" for apps")
    comp=_HC(shell)
    apps=[]
    dirs=["/usr/bin","/bin"]
    for d in dirs
      df=comp.File(d)
      if not df then continue
      for f in df.get_files;apps.push({"name":f.name,"dir":d});end for
    end for
    hf=comp.File("/home")
    if hf then
      for ud in hf.get_folders
        if ud.name==_gt then continue
        for f in ud.get_files;if f.name.indexOf(".exe")!=null then apps.push({"name":f.name,"dir":ud.path});end for
      end for
    end if
    if apps then
      while true
        if gco.H then break
        _p ""
        curDir=""
        row=""
        col=0
        for a in apps
          if a.dir!=curDir then
            if row then _p "  "+row
            row=""
            col=0
            if curDir then _p ""
            curDir=a.dir
            _p GY("  "+curDir+":")
          end if
          row=row+WH(_lj("["+_s(__a_idx+1)+"] ",5))+BL(_lj(a.name,18))
          col=col+1
          if col==4 then
            _p "  "+row
            row=""
            col=0
          end if
        end for
        if row then _p "  "+row
        sel=_uig("[App # + args, or 'b' to go back] > ")
        if not sel or _tl(sel)=="b" then break
        parts=split(sel.trim," ")
        si=_ti(parts[0])
        if si isa number and si>=1 and si<=apps.len then
          appPath=apps[si-1].dir+"/"+apps[si-1].name
          if parts.len>1 then
            appArgs=parts[1:].join(" ")
            shell.launch(appPath,appArgs)
          else
            shell.launch(appPath)
          end if
        else
          _pe(_iv)
        end if
      end while
    else
      prt("No apps found")
    end if
  end function
  cm.l=function;if not shell then return prt(_ns+" for local scan");localScan(shell);end function
  cm.n=function;if not shell then return prt(_ns+" for LAN scan");scanLAN(shell);end function
  cm.dg=function;if not shell then return prt(_ns+" for dig");_digS(shell);end function
  cm.f=function;browseFiles(ex,u);end function
  cm.d=function;if not shell or _HC(shell).public_ip==gco.home.ip then return _pe("Only on remote hosts");downloadFile(ex);end function
  cm.r=function;renameFile(ex);end function
  cm.u=function;if not shell then return prt(_ns+" to upload");if _HC(shell).public_ip==gco.home.ip then return _pe("Only on remote hosts");uploadFile(shell);end function
  cm.pc=function
    tc=0
    for k in gco._nc.indexes
      cl=gco._nc[k]
      if not cl.len then continue
      _p GN("  "+k+":")
      for c in cl;_p WH("    "+_lj(c.user,16))+GN(c.pass);end for
      tc=tc+cl.len
    end for
    if tc==0 then _p GY("  No cached credentials") else _p GY("  "+_s(gco._nc.len)+" hosts, "+_s(tc)+" creds")
  end function
  cm.p=function
    creds=_gcr2(ex,exType)
    if creds.len then
      _p GY("  Cached creds for this host:")
      for c in creds;_p WH("    "+_lj(c.user,16))+GN(c.pass);end for
    else
      _p GY("  No cached creds for this host")
    end if
    pw=_uig("[Add root password or enter to skip] > ")
    if pw and pw.trim.len then
      _acr(shell,"root",pw.trim)
      _ps("Added root:"+pw.trim)
    end if
  end function
  cm.rs=function;rshellMenu(shell);end function
  cm.dv=function;if shell then _devMenu(shell) else _pe(_ns);end function
  cm.wf=function;if shell then _wifiCrack(shell) else _pe(_ns);end function
  cm.po=function;_pObjectMenu(shell);end function
  cm.g=function;_grabAccounts(ex);end function
  cm.pv=function;if not shell then return _pe(_ns+" to pivot");_pivotScanner(shell);end function
  cm.dy=function;if not shell or _HC(shell).public_ip==gco.home.ip then return _pe("Only on remote shells");_deploy(shell);end function
  cm["0d"]=function;_show0dayStatus;end function
  cm.ld=function;if not shell then return _pe(_ns);lPath=_uig("[lib path on remote, e.g. /lib/crypto.so] > ");if lPath and lPath.trim.len then _loadRemoteLib(shell,lPath.trim);end function
  cm.tr=function;_tree(ex);end function
  cm.rl=function;_init;end function
  cm.w=function;if _cwl(ex) then wipeLog(ex) else prt("No write permission to system.log");end function
  cm.i=function
    if exType==_sh then
      wIP=_HC(ex).public_ip
    else if exType==_cm then
      wIP=ex.public_ip
    else
      wIP=null
    end if
    wTarget=_uig("[whois target"+((wIP!=null)*(" ["+wIP+"]"))+"] > ")
    if not wTarget or not len(wTarget.trim) then
      if wIP then _whois(wIP) else _pe("No target specified")
    else
      _whois(wTarget.trim)
    end if
  end function
  while true
    if gco.H then break
    _p OR(_hb("Host"))
    pCnt=_cpw(ex)
    _p _mi("c","  Crack ("+_s(pCnt)+" accounts)")
    _cip=[]
    if shell then _cip=_gcr(shell)
    if shell and _cip.len and _gu(ex)!="root" then _p _mi("s","  Su ("+_s(_cip.len)+" cracked creds)")
    _p _mi("g","  Grab emails/banks")
    _p _mi("f","  Browse files")
    if shell then
      aCnt=_cap(shell)
      _p _mi("a","  Apps ("+_s(aCnt)+")")
    end if
    _p _mi("d","  Download   ")+_mi("u","  Upload     ")+_mi("r","  Rename")
    if shell then
      _p _mi("l","  Local scan ")+_mi("n","  LAN scan   ")+_mi("dg"," Dig")
      _p _mi("wf"," WiFi       ")+_mi("po"," PObject    ")+_mi("dv"," Devices")
      _p _mi("pv"," Pivot "+_selfName+" to this host")
      if _HC(shell).public_ip!=gco.home.ip then _p _mi("dy"," Deploy bin from main")
    end if
    rsC=gco.rshell_shells.len
    rsSrv=gco.rshell_servers.len
    _p _mi("rs"," RShell ("+_s(rsSrv)+"/"+_s(rsC)+")")
    _p _mi("e","  Echo >|>>  ")+_mi("w","  wipe   ")+_mi("i","  whois  ")+_mi("0d"," 0day")
    _p _mi("p","  passwords  ")+_mi("pc"," all cached creds")+_mi("ld"," load lib")
    _p _mi("tr"," Tree        ")+_mi("rl"," Reload init")
    _p _bk+GY("  Type ")+YL("home")+GY(" to return to main")
    u=_gu(ex)
    if exType==_sh then
      h=_HC(ex).public_ip
    else if exType==_cm then
      h=ex.public_ip
    else
      h=gco._eip
    end if
    ans=_ui(GN("["+u+"@"+h+" "+exType+"] ")+">"+" ")
    if ans and _tl(ans)=="home" then
      gco.H=true
      break
    end if
    if not ans or not len(ans.trim) then continue
    if _tl(ans)=="b" then break
    _comp=null
    if shell then
      _comp=_HC(shell)
    else if exType==_cm then
      _comp=ex
    end if
    if _sw(ans,"echo ") then
      if _comp then _echo(ans[5:],_comp) else _pe("No computer access")
      continue
    end if
    if _sw(ans,"e ") then
      if _comp then _echo(ans[2:],_comp) else _pe("No computer access")
      continue
    end if
    if ans[0]=="!" and shell then
      _pt=trim(ans[1:]).split(" ")
      _cmd=_pt[0]
      _args=""
      if _pt.len>1 then _args=_pt[1:].join(" ")
      if _cmd==_ch and _pt.len>=3 then
        rflag=(_args.lower.indexOf("-r")!=null)
        perm=null
        tp=_pt[-1]
        for _pi in _pt[1:];if _ti(_pi) isa number and _pi.len==3 then perm=_pi;end for
        if perm then
          pf=_comp.File(tp)
          if not pf then pf=_comp.File(current_path+"/"+tp)
          if not pf then
            _pe("File not found: "+tp)
            continue
          end if
        for ow in [[_ti(perm[0]),"u"],[_ti(perm[1]),"g"],[_ti(perm[2]),"o"]]
          v=ow[0];w=ow[1]
          if rflag then r=pf.chmod(w+"-rwx",rflag) else r=pf.chmod(w+"-rwx")
          if r isa string and r.len then break
          if bitAnd(v,4) then
            if rflag then r=pf.chmod(w+"+r",rflag) else r=pf.chmod(w+"+r")
          end if
          if bitAnd(v,2) then
            if rflag then r=pf.chmod(w+"+w",rflag) else r=pf.chmod(w+"+w")
          end if
          if bitAnd(v,1) then
            if rflag then r=pf.chmod(w+"+x",rflag) else r=pf.chmod(w+"+x")
          end if
        end for
        _ps("chmod "+perm+" "+tp)
        continue
        end if
      end if
      if _cmd=="mkdir" and _args.len then
        dp=_args.trim
        if dp.indexOf("/")!=0 then dp=_hd(u)+"/"+dp
        ps=dp.split("/");fn=ps[-1];dr=ps[:-1].join("/")
        if not dr then dr="/"
        r=_comp.create_folder(dr,fn)
        if r isa string and r.len then _pe(r) else _ps("Created "+dp)
        continue
      end if
      if _cmd=="qrm" and _args.len then
        rf=_comp.File(_args)
        if not rf then rf=_comp.File(current_path+"/"+_args)
        if not rf then
          _pe("Not found: "+_args)
        else
          qrm(_comp,rf)
          _ps("Removed "+rf.path)
        end if
        continue
      end if
      _bin=null
      if _comp.File("/bin/"+_cmd) then _bin="/bin/"+_cmd
      if not _bin and _comp.File("/usr/bin/"+_cmd) then _bin="/usr/bin/"+_cmd
      if _bin then
        if _args.len then
          shell.launch(_bin,_args)
        else if _cmd=="ls" then
          if u=="root" then shell.launch(_bin,"/root") else shell.launch(_bin,"/home/"+u)
        else
          shell.launch(_bin)
        end if
      else
        _pe("Not found: "+_cmd)
      end if
      continue
    end if
    ch=_tl(ans)
    if hasIndex(cm,ch) then cm[ch] else _pe("Unknown action")
  end while
end function
_exR=function(ex)
  if ex isa string then return _pe(ex)
  if not ex then return prt("Exploit returned null")
  obj=_to(ex)
  if obj==_sh or obj==_fs then
    _ps("Got shell!")
    _p OR(_uu)+WH(_gu(ex))
    _p OR(_uh)+WH(_HC(ex).public_ip)
    _exM(ex,_sh)
  else if obj==_cm then
    _ps("Got computer!")
    _p OR(_uu)+WH(_gu(ex))
    _p OR(_uh)+WH(ex.public_ip)
    _exM(ex,_cm)
  else if obj=="file" then
    _ps("Got file!")
    _p OR(_uu)+WH(_gu(ex))
    _p OR(_up)+WH(ex.path)
    _p OR("    Name: ")+WH(ex.name)
    _exM(ex,"file")
  else if ex isa number then
    _ps(_fd)
  else
    prt(_rt+_to(ex))
  end if
end function
_buildLanScan=function(shell)
  comp=_HC(shell)
  if not _hasNet(comp) then return _pe("No internet connection")
  u=_gu(shell)
  home=_hd(u)
  if gco.hasIndex("scanlan_result") then gco.scanlan_result=null
  code="deep=function(t,s);R=[];if indexOf(s,t)!=null then return R;D={""ip"":t,""ports"":[],""devices"":[],""type"":""device"",""fw"":false,""fwd"":false};if not ping(get_shell,t) then;R.push(D);return R;end if;s.push(t);r=get_router(t);if r!=null then;F=firewall_rules(r);if F isa list and F then;D[""fw""]=true;for z in F;if indexOf(z,""DENY"")!=null then D[""fwd""]=true;end for;end if;if local_ip(get_router(public_ip(r)))==t then;D[""type""]=""edge"";else;if get_switch(t)!=null then D[""type""]=""switch"" else D[""type""]=""router"";end if;for p in device_ports(r,t);if port_number(p)==8080 then push(D[""ports""],{""pn"":0,""lip"":local_ip(r),""pip"":public_ip(r),""svc"":""router"",""ver"":kernel_version(r),""st"":""open""});d={};d[""pn""]=port_number(p);d[""lip""]=get_lan_ip(p);d[""pip""]=public_ip(r);i=split(port_info(r,p),"" "");d[""svc""]=i[0];d[""ver""]=i[1];d[""st""]=""open"";push(D[""ports""],d);end for;v=devices_lan_ip(r);for c2 in v;if indexOf(s,c2)!=null or c2==t then continue;u=deep(c2,s);for l in u;push(D[""devices""],l);end for;end for;else;M=get_router(s[0]);if M!=null then;for p in device_ports(M,t);d={};d[""pn""]=port_number(p);d[""lip""]=get_lan_ip(p);d[""pip""]=public_ip(M);i=split(port_info(M,p),"" "");d[""svc""]=i[0];d[""ver""]=i[1];d[""st""]=""open"";pn=d[""pn""];if pn==37777 then D[""type""]=""CCTV"";if pn==1883 then D[""type""]=""SAPP"";if pn==1222 then D[""type""]=""RSHL"";if pn==5555 then D[""type""]=""ADB"";push(D[""ports""],d);end for;end if;end if;R.push(D);return R;end function;get_custom_object[""scanlan_result""]=deep(local_ip(get_router),[])"
  comp.touch(home,".x_ls.src")
  f=comp.File(home+"/.x_ls.src")
  if not f then return _pe("Failed to create LAN scanner")
  f.set_content(code)
  r=shell.build(f.path,home)
  if r!="" then
    f=comp.File(home+"/.x_ls.src")
    if f then qrm(comp,f)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_ls")
  f=comp.File(home+"/.x_ls.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_ls")
  if f then qrm(comp,f)
  if not gco.hasIndex("scanlan_result") or not gco.scanlan_result then return _pe("LAN scan returned no results")
  return gco.scanlan_result
end function
scanLAN=function(remoteShell)
  if remoteShell==_ls then rMetax=_scn.metax else rMetax=_grM(remoteShell)
  if not rMetax then return
  hMetax=_scn.metax
  comp=_HC(remoteShell)
  lip=comp.local_ip
  if not lip then lip=comp.public_ip
  prt("Building network map...")
  lanData=_buildLanScan(remoteShell)
  if not lanData then return
  devList=[]
  _flatten=function(devices);for dev in devices;dev.you=false;if dev.ip==lip then dev.you=true;devList.push(dev);if dev.devices then _flatten(dev.devices);end for;end function
  _flatten(lanData)
  if not devList then return prt("No LAN devices found")
  while true
    if gco.H then break
    _p OR("--- LAN Devices ("+comp.public_ip+") ---")
    _p GY(_lj("#",5))+GY(_lj("LAN IP",18))+GY(_lj("TYPE",12))+GY(_lj("FW",5))+GY("PORTS")
    for d in devList
      di=__d_idx+1
      tag=d.type
      clr="BL"
      if tag=="edge" then
        tStr="Edge Rtr"
        clr="WH"
      else if tag=="router" then
        tStr="Router"
        clr="WH"
      else if tag=="switch" then
        tStr="Switch"
        clr="YL"
      else if tag=="CCTV" then
        tStr="Camera"
        clr="OR"
      else if tag=="SAPP" then
        tStr="Appliance"
        clr="OR"
      else if tag=="RSHL" then
        tStr="RShell"
        clr="PR"
      else if tag=="ADB" then
        tStr="ADB"
        clr="OR"
      else
        tStr="Device"
      end if
      fwStr="-"
      fwClr="GY"
      if d.fw then
        fwStr="F"
        if d.fwd then fwClr="RD" else fwClr="GN"
      end if
      portNums=[]
      for pt in d.ports;portNums.push(_s(pt.pn));end for
      pStr=""
      if portNums then pStr=WH(join(portNums,","))
      youTag=""
      if d.you then youTag=" "+GN("[YOU]")
      line=_lj(_s(di),5)+_lj(d.ip,18)+_lj(tStr,12)+_lj(fwStr,5)
      cLine=WH(line[:5])+YL(line[5:23])
      if clr=="WH" then
        cLine=cLine+WH(line[23:35])
      else if clr=="YL" then
        cLine=cLine+YL(line[23:35])
      else if clr=="OR" then
        cLine=cLine+OR(line[23:35])
      else if clr=="PR" then
        cLine=cLine+PR(line[23:35])
      else
        cLine=cLine+BL(line[23:35])
      end if
      if fwClr=="RD" then
        cLine=cLine+RD(line[35:40])
      else if fwClr=="GN" then
        cLine=cLine+GN(line[35:40])
      else
        cLine=cLine+GY(line[35:40])
      end if
      _p cLine+pStr+youTag
    end for
    c=_uig("[Device # to scan, 'r' refresh, 'b' back] > ")
    if not c or _tl(c)=="b" then return
    if _tl(c)=="r" then
      prt("Refreshing network map...")
      lanData=_buildLanScan(remoteShell)
      if not lanData then return
      devList=[]
      _flatten(lanData)
      continue
    end if
    sel=_ti(c.trim)
    if not sel isa number or sel<1 or sel>devList.len then
      _pe(_iv)
      continue
    end if
    dev=devList[sel-1]
    dTargets=[]
    dExit=false
    while true
      if gco.H then break
      _p OR("--- Ports on ")+YL(dev.ip)+OR(" (")+BL(dev.type)+OR(") ---")
      _p GY(_lj("PORT",8))+GY(_lj("STATE",9))+GY(_lj("SERVICE",14))+GY(_lj("VERSION",11))+GY("LAN")
      for pt in dev.ports;if pt.st=="open" then state=GN(_lj("open",9)) else state=RD(_lj("closed",9));_p GN(_lj(_s(pt.pn),8))+state+BL(_lj(pt.svc,14))+BL(_lj(pt.ver,11))+LM(pt.lip);end for
      if dTargets then
        prt("Previously scanned:")
        for tgt in dTargets
          i=__tgt_idx+1
          total=tgt.shells+tgt.computers+tgt.files+tgt.bounces+tgt.firewalls+tgt.unknown
          t=PR("[")+WH(_s(i))+PR("] ")+YL("• ")+OR(tgt.ln)+WH(" ("+tgt.ver+") ")
          _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN(_s(tgt.port))
          bd=""
          if tgt.port==0 then bd=YL(" - ")+WH("Bo")+OR(":")+PR(_s(tgt.bounces))+YL(" - ")+WH("Fw")+OR(":")+LM(_s(tgt.firewalls))
          _p "    "+WH("Sh")+OR(":")+GN(_s(tgt.shells))+YL(" - ")+WH("Co")+OR(":")+YL(_s(tgt.computers))+YL(" - ")+WH("Fi")+OR(":")+RD(_s(tgt.files))+bd+YL(" - ")+WH("Un")+OR(":")+ER(_s(tgt.unknown))
        end for
      end if
      _p ""
      if dev.ports.len==1 and not dTargets then
        prt("Single port, auto-scanning...")
        pc="a"
      else
        pc=_uig("[Port #, 'a' scan all, 'b' back, home] > ")
      end if
      if not pc then continue
      if _tl(pc)=="b" then break
      scanPts=[]
      if _tl(pc)=="a" then
        scanPts=dev.ports
      else
        psel=_ti(pc.trim)
        if not psel isa number then
          _pe(_iv)
          continue
        end if
        found=false
        for pt in dev.ports;if pt.pn==psel then;scanPts.push(pt);found=true;break;end if;end for
        if not found then
          if dTargets and psel>0 and psel<=dTargets.len then
            scanPts=[]
          else
            _pe("Port not found: "+_s(psel))
            continue
          end if
        end if
      end if
      newPts=[]
      for pt in scanPts;already=false;for tgt in dTargets;if tgt.port==pt.pn then;already=true;break;end if;end for;if not already then newPts.push(pt);end for
      if scanPts and not newPts then
        ans=_ui(YL("[!] Already scanned. Rescan? (y/N) "))
        if ans and _tl(ans)=="y" then newPts=scanPts
      end if
      if newPts then
        prt("Scanning "+_s(newPts.len)+" ports for exploits...")
        _p ""
        for pt in newPts
          session=rMetax.net_use(pt.lip,pt.pn)
          if not session then continue
          lib=session.dump_lib
          if not lib then continue
          ln=lib.lib_name
          ver=lib.version
          addresses=hMetax.scan(lib)
          if not addresses then continue
          exploits=[]
          for addr in addresses
            vulnInfo=hMetax.scan_address(lib,addr)
            if not vulnInfo then continue
            for line in vulnInfo.split(char(10))
              if line.indexOf(_uc)==0 then
                s=line.indexOf("<b>")+3
                d2=line.indexOf("</b>")
                if s>2 and d2!=null then
                  unsecured=line[s:d2]
                  exploits.push({"addr":addr,"val":unsecured})
                end if
              end if
            end for
          end for
          if not exploits then continue
          p=lib.is_patched(1)
          if p isa string then
            patchStr=GN("Patched To: "+p)
          else if p==1 then
            patchStr=GN("Patched")
          else
            patchStr=RD("Not Patched")
          end if
          ct={"shells":0,"computers":0,"files":0,"bounces":0,"firewalls":0,_uk:0}
          classified=[]
          for e in exploits;ex=lib.overflow(e.addr,e.val);r=_classifyEx(ex,ln);if ct.hasIndex(r[0]+"s") then ct[r[0]+"s"]=ct[r[0]+"s"]+1 else ct.unknown=ct.unknown+1;classified.push({"addr":e.addr,"val":e.val,"type":r[0],"user":r[1]});end for
          dTargets.push({"lib":lib,"ln":ln,"ver":ver,"lan":pt.lip,"port":pt.pn,"exploits":classified,"patchStr":patchStr,"shells":ct.shells,"computers":ct.computers,"files":ct.files,"bounces":ct.bounces,"firewalls":ct.firewalls,_uk:ct.unknown})
        end for
      end if
      if not dTargets then
        prt("No exploitable services found")
        if dev.ports.len==1 then break
        continue
      end if
    while true
      if gco.H then break
      _p OR("--- Attack vectors on ")+YL(dev.ip)+OR(" ---")
      for tgt in dTargets
        i=__tgt_idx+1
        total=tgt.shells+tgt.computers+tgt.files+tgt.bounces+tgt.firewalls+tgt.unknown
        t=PR("[")+WH(_s(i))+PR("] ")+YL("• ")+OR(tgt.ln)+WH(" ("+tgt.ver+") ")
        _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN(_s(tgt.port))
        _p GN("    |-> ")+tgt.patchStr
        _p "    "+GN(_s(total))+WH(" exploits")
        bd=""
        if tgt.port==0 then bd=YL(" - ")+WH("Bo")+OR(":")+PR(_s(tgt.bounces))+YL(" - ")+WH("Fw")+OR(":")+LM(_s(tgt.firewalls))
        _p "    "+WH("Sh")+OR(":")+GN(_s(tgt.shells))+YL(" - ")+WH("Co")+OR(":")+YL(_s(tgt.computers))+YL(" - ")+WH("Fi")+OR(":")+RD(_s(tgt.files))+bd+YL(" - ")+WH("Un")+OR(":")+ER(_s(tgt.unknown))
      end for
      c2=_uig("[Target #, 'b' back, 'x' exit, home] > ")
      if not c2 then continue
      if _tl(c2)=="b" then break
      if _tl(c2)=="x" then
        dExit=true
        break
      end if
      tsel=_ti(c2.trim)
      if not tsel isa number or tsel<1 or tsel>dTargets.len then
        _pe(_iv)
        continue
      end if
      tgt=dTargets[tsel-1]
      while true
        if gco.H then break
        _p OR("--- Exploits ")+WH(tgt.ln)+GY(":")+BL(tgt.ver)+OR(" ")+YL(dev.ip+":"+_s(tgt.port))+OR(" ---")
        _p GY(_lj("#",5))+GY(_lj("TYPE",12))+GY(_lj("USER",12))+GY(_lj("ADDRESS",14))+GY("VALUE")
        for e in tgt.exploits;e.i=__e_idx+1;_p _exTag(e);end for
        c3=_uig("[Exploit #, 'c' custom, 'ba' bounce all, 'b' back, 'x' exit, home] > ")
        if not c3 then continue
        if _tl(c3)=="b" then break
        if _tl(c3)=="x" then
          dExit=true
          break
        end if
        if _tl(c3)=="c" then
          ca=_uig("[Memory address] > ")
          if not ca or not ca.trim.len then continue
          cv=_uig("[Unsafe check value] > ")
          if not cv or not cv.trim.len then continue
          ex=tgt.lib.overflow(ca.trim,cv.trim)
          _exR(ex)
          continue
        end if
        if _tl(c3)=="ba" then
          bip=_ui(OR("[Bounce target IP] > "))
          if not bip or not _vi(bip.trim) then
            _pe(_iip)
            continue
          end if
          bip=bip.trim
          for ne in tgt.exploits
            if ne.type!="null" then continue
            prt("Trying "+ne.addr+" "+ne.val+" -> "+bip)
            ex=overflow(tgt.lib,ne.addr,ne.val,bip)
            if not ex then
              _p GY("    null")
              continue
            end if
            if ex isa string then
              _p GY("    "+ex)
              continue
            end if
            _exR(ex)
          end for
          continue
        end if
        esel=_ti(c3.trim)
        if not esel isa number or esel<1 or esel>tgt.exploits.len then
          _pe(_iv)
          continue
        end if
        exploit=tgt.exploits[esel-1]
        gco.meta_local=null
        if exploit.type=="bounce" then
          bounceIP=_ui(OR("[Bounce target IP] > "))
          if not bounceIP or not _vi(bounceIP.trim) then
            _pe(_iip)
            continue
          end if
          ex=tgt.lib.overflow(exploit.addr,exploit.val,bounceIP.trim)
        else if exploit.type=="null" then
          _p GY(_en)
          ans=_uig("[Password or bounce IP, or 'b' to skip] > ")
          if not ans or _tl(ans)=="b" then continue
          ex=tgt.lib.overflow(exploit.addr,exploit.val,ans.trim)
          if not ex then
            prt("Exploit returned null again")
            continue
          else if ex isa string then
            _pe(ex)
            continue
          end if
          obj=_to(ex)
          if obj==_cm then
            _ps("Got computer (bounce)!")
            _p OR(_uu)+WH(_gu(ex))
            _p OR(_uh)+WH(ex.public_ip)
            _exM(ex,_cm)
          else
            _ps("Password change may have succeeded!")
          end if
          continue
        else
          ex=tgt.lib.overflow(exploit.addr,exploit.val)
        end if
        _exR(ex)
      end while
      if dExit then break
    end while
    if dExit then break
    end while
  end while
end function
_grR=function(shell)
  mk=_HC(shell).public_ip+":"+_HC(shell).local_ip
  if gco.routers.hasIndex(mk) then return gco.routers[mk]
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  gco._dgR=null
  comp.touch(home,".x_gr.src")
  f=comp.File(home+"/.x_gr.src")
  if not f then return null
  f.set_content("c=host_computer(get_shell);if c.public_ip and c.public_ip!=""0.0.0.0"" then get_custom_object[""_dgR""]=get_router")
  r=build(shell,path(f),home)
  if r!="" then
    f=comp.File(home+"/.x_gr.src")
    if f then qrm(comp,f)
    return null
  end if
  shell.launch(home+"/.x_gr")
  f=comp.File(home+"/.x_gr.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_gr")
  if f then qrm(comp,f)
  if gco._dgR then gco.routers[mk]=gco._dgR
  return gco._dgR
end function
_digBo=function(shell,testIP=null)
  comp=_HC(shell)
  lip=comp.local_ip
  pip=comp.public_ip
  if lip==homeLIP then rMetax=metax else rMetax=_grM(shell)
  if not rMetax then return _pe("Cannot load metaxploit")
  hMetax=_scn.metax
  libDir=comp.File("/lib")
  if not libDir then return _pe("Cannot access /lib")
  libFiles=libDir.get_files
  if not libFiles then return _pe("No libraries in /lib")
  if lip==homeLIP then router=_gr else router=_grR(shell)
  if not router then return _pe("No router found")
  if testIP then
    prt("Using test IP: "+testIP)
  else
    lanIPs=router.devices_lan_ip
    for ip in lanIPs;if ip!=lip then;testIP=ip;break;end if;end for
    if not testIP then return _pe("No LAN targets to test bounce")
  end if
  prt("Scanning /lib for bounce exploits...")
  best=null
  for lf in libFiles
    if lf.name=="metaxploit.so" then continue
    lib=rMetax.load(lf.path)
    if not lib then continue
    addresses=hMetax.scan(lib)
    if not addresses then continue
    for addr in addresses
      vulnInfo=hMetax.scan_address(lib,addr)
      if not vulnInfo then continue
      for line in vulnInfo.split(char(10))
        if line.indexOf(_uc)!=0 then continue
        s=line.indexOf("<b>")+3
        d2=line.indexOf("</b>")
        if s<3 or d2==null then continue
        unsec=line[s:d2]
        ex=lib.overflow(addr,unsec,testIP)
        if not ex or _to(ex)!=_cm then continue
        usr=_gu(ex)
        _ps("Bounce: "+lf.name+" ["+addr+"] -> "+usr)
        if usr=="root" then
          best={"lib":lib,"addr":addr,"val":unsec,"user":usr,"ln":lf.name}
          break
        end if
        if not best or (best.user==_gt and usr!=_gt) then best={"lib":lib,"addr":addr,"val":unsec,"user":usr,"ln":lf.name}
      end for
      if best and best.user=="root" then break
    end for
    if best and best.user=="root" then break
  end for
  return best
end function
_digX=function(shell,bounce,extreme)
  comp=_HC(shell)
  lip=comp.local_ip
  if lip==homeLIP then router=_gr else router=_grR(shell)
  if not router then return _pe("No router found")
  lanIPs=router.devices_lan_ip
  results=[]
  seen={}
  rIPs=[]
  for ip in lanIPs;dp=router.device_ports(ip);if not dp then continue;for q in dp;if _pn(q)==8080 then;rIPs.push(ip);break;end if;end for;end for
  if not rIPs then
    _pe("No routers found on LAN")
    return results
  end if
  exLimit=50
  if extreme then exLimit=255
  prt("Sweeping "+_s(rIPs.len)+" subnet(s) (0-"+_s(exLimit)+")...")
  _p ""
  for rip in rIPs
    parts=rip.split("\.")
    prefix=parts[0]+"."+parts[1]+"."+parts[2]+"."
    fails=0
    i=0
    while i<=exLimit
      t=prefix+_s(i)
      if t==lip or seen.hasIndex(t) then
        i=i+1
        continue
      end if
      seen[t]=true
      ex=bounce.lib.overflow(bounce.addr,bounce.val,t)
      if ex==null then
        if fails>=30 then break
        fails=fails+1
        i=i+1
        continue
      end if
      if _to(ex)!=_cm then
        i=i+1
        continue
      end if
      usr=_gu(ex)
      results.push({"ip":t,"ex":ex,"user":usr})
      _p GN("  [+] ")+YL(t)+GY(" -> ")+WH(usr)
      fails=0
      i=i+1
    end while
  end for
  return results
end function
_digC=function(results,fname)
  items=[]
  denied=0
  for r in results
    c2=r.ex
    hDir=c2.File("/home")
    if not hDir then
      denied=denied+1
      continue
    end if
    for ud in hDir.get_folders
      mf=c2.File(ud.path+"/Config/"+fname)
      if not mf or not _hp(mf,"r") then continue
      mc=_gc(mf)
      if not mc then continue
      p=mc.split(":")
      if p.len>=2 then items.push({"ip":r.ip,"lip":c2.local_ip,"user":ud.name,"acct":p[0],"hash":p[1]})
    end for
  end for
  if denied then _pw(_s(denied)+"/"+_s(results.len)+" hosts denied (permissions)")
  return items
end function
_crL=function(items)
  if not crypto then return
  cur=items
  while true
    if gco.H then break
    ans=_uig("[#s/a=all/f=filter/x=done] > ")
    if not ans or _tl(ans)=="x" then break
    ans=_tl(ans)
    if ans.indexOf("f ")==0 then
      q=ans[2:]
      cur=[]
      idx=0
      for e in items
        if e.ip.indexOf(q)!=null or e.user.lower.indexOf(q)!=null or e.acct.lower.indexOf(q)!=null or e.hash.indexOf(q)!=null then
          _p GY(_lj(_s(idx),4))+YL(_lj(e.ip,18))+WH(_lj(e.user,14))+BL(_lj(e.acct,28))+GY(e.hash)
          cur.push(e)
        end if
        idx=idx+1
      end for
      _ps(_s(cur.len)+"/"+_s(items.len)+" match")
      continue
    end if
    if ans=="f" then
      cur=items
      idx=0
      for e in items;_p GY(_lj(_s(idx),4))+YL(_lj(e.ip,18))+WH(_lj(e.user,14))+BL(_lj(e.acct,28))+GY(e.hash);idx=idx+1;end for
      _ps("Filter cleared")
      continue
    end if
    tc=[]
    if ans=="a" then
      tc=cur
    else
      for n in ans.split(",");n=n.trim;if n==_s(_ti(n)) and _ti(n)>=0 and _ti(n)<items.len then tc.push(items[_ti(n)]);end for
    end if
    for e in tc;p=crypto.decipher(e.hash);if p then _p GN("  ")+BL(e.acct)+GN(" -> ")+YL(p);end for
  end while
end function
_digE=function(results)
  emails=_digC(results,"Mail.txt")
  _p OR("--- Emails ("+_s(emails.len)+") ---")
  if not emails then return prt("No emails found")
  _p GY(_lj("#",4)+_lj("IP",18)+_lj("USER",14)+_lj("ACCOUNT",28)+"HASH")
  idx=0
  for e in emails;_p GY(_lj(_s(idx),4))+YL(_lj(e.ip,18))+WH(_lj(e.user,14))+BL(_lj(e.acct,28))+GY(e.hash);idx=idx+1;end for
  _crL(emails)
end function
_digB=function(results)
  banks=_digC(results,"Bank.txt")
  _p OR("--- Banks ("+_s(banks.len)+") ---")
  if not banks then return prt("No bank accounts found")
  _p GY(_lj("#",4)+_lj("IP",18)+_lj("USER",14)+_lj("ACCOUNT",28)+"HASH")
  idx=0
  for b in banks;_p GY(_lj(_s(idx),4))+YL(_lj(b.ip,18))+WH(_lj(b.user,14))+BL(_lj(b.acct,28))+GY(b.hash);idx=idx+1;end for
  _crL(banks)
end function
_digR=function(results)
  rshells=_digC(results,"Mail.txt")
  _p OR("--- RShell Data ("+_s(rshells.len)+") ---")
  if not rshells then return prt("No rshell data found")
  _p GY(_lj("#",4)+_lj("IP",18)+_lj("LAN",18)+_lj("USER",14)+_lj("ACCOUNT",28)+"HASH")
  idx=0
  for r in rshells;_p GY(_lj(_s(idx),4))+YL(_lj(r.ip,18))+YL(_lj(r.lip,18))+WH(_lj(r.user,14))+BL(_lj(r.acct,28))+GY(r.hash);idx=idx+1;end for
  _crL(rshells)
end function
_digU=function(results)
  rootHash=null
  allH=[]
  denied=0
  seen={}
  for r in results
    c2=r.ex
    lip2=c2.local_ip
    pf=c2.File("/etc/passwd")
    if not pf or not _hp(pf,"r") then
      denied=denied+1
      continue
    end if
    content=_gc(pf)
    if not content then continue
    for line in content.split(char(10))
      if not line then continue
      parts=line.split(":")
      if parts.len<2 then continue
      un=parts[0]
      ph=parts[1]
      if un=="root" then
        if not rootHash then rootHash=ph
        continue
      end if
      key=lip2+":"+un
      if seen.hasIndex(key) then continue
      seen[key]=true
      rec={"ip":lip2,"user":un,"phash":ph}
      hDir=c2.File("/home/"+un)
      if hDir then
        mf=c2.File("/home/"+un+"/Config/Mail.txt")
        if mf and _hp(mf,"r") then
          mc=_gc(mf)
          if mc then
            mp=mc.split(":")
            if mp.len>=2 then
              rec.email=mp[0]
              rec.ehash=mp[1]
            end if
          end if
        end if
        bf=c2.File("/home/"+un+"/Config/Bank.txt")
        if bf and _hp(bf,"r") then
          bc=_gc(bf)
          if bc then
            bp=bc.split(":")
            if bp.len>=2 then
              rec.bank=bp[0]
              rec.bhash=bp[1]
            end if
          end if
        end if
      end if
      allH.push(rec)
    end for
  end for
  if denied then _pw(_s(denied)+"/"+_s(results.len)+" hosts denied (permissions)")
  if rootHash then
    _p OR("ROOT: ")+GY(rootHash)
    _p ""
  end if
  if not allH then return prt("No user data found")
  _p OR("--- User Data ("+_s(allH.len)+") ---")
  idx=0
  for h in allH;_p GY(_lj(_s(idx),4))+YL(h.ip);_p GY("      ")+WH(h.user)+GY(" ")+GY(h.phash);if h.hasIndex("email") then _p GY("      ")+BL(h.email)+GY(" ")+GY(h.ehash);if h.hasIndex("bank") then _p GY("      ")+BL(h.bank)+GY(" ")+GY(h.bhash);idx=idx+1;end for
  if not crypto then return
  while true
    if gco.H then break
    ans=_uig("[#s/a=all/f=filter/x=done] > ")
    if not ans or _tl(ans)=="x" then break
    ans=_tl(ans)
    if ans.indexOf("f ")==0 then
      q=ans[2:]
      cnt=0
      idx=0
      for h in allH
        mt=h.ip.indexOf(q)!=null or h.user.lower.indexOf(q)!=null or h.phash.indexOf(q)!=null
        if not mt and h.hasIndex("email") then mt=h.email.lower.indexOf(q)!=null
        if not mt and h.hasIndex("bank") then mt=h.bank.lower.indexOf(q)!=null
        if mt then
          _p GY(_lj(_s(idx),4))+YL(h.ip)
          _p GY("      ")+WH(h.user)+GY(" ")+GY(h.phash)
          if h.hasIndex("email") then _p GY("      ")+BL(h.email)+GY(" ")+GY(h.ehash)
          if h.hasIndex("bank") then _p GY("      ")+BL(h.bank)+GY(" ")+GY(h.bhash)
          cnt=cnt+1
        end if
        idx=idx+1
      end for
      _ps(_s(cnt)+"/"+_s(allH.len)+" match")
      continue
    end if
    if ans=="f" then
      idx=0
      for h in allH;_p GY(_lj(_s(idx),4))+YL(h.ip);_p GY("      ")+WH(h.user)+GY(" ")+GY(h.phash);if h.hasIndex("email") then _p GY("      ")+BL(h.email)+GY(" ")+GY(h.ehash);if h.hasIndex("bank") then _p GY("      ")+BL(h.bank)+GY(" ")+GY(h.bhash);idx=idx+1;end for
      _ps("Filter cleared")
      continue
    end if
    tc=[]
    if ans=="a" then
      tc=allH
    else
      for n in ans.split(",");n=n.trim;if n==_s(_ti(n)) and _ti(n)>=0 and _ti(n)<allH.len then tc.push(allH[_ti(n)]);end for
    end if
    for h in tc
      _p GN("  "+h.ip+" ")+WH(h.user)
      wh=_uig("  [p]asswd [e]mail [b]ank [a]ll > ")
      if not wh then continue
      wh=_tl(wh)
      if wh=="p" or wh=="a" then
        p=crypto.decipher(h.phash)
        if p then _p GN("    passwd -> ")+YL(p) else _p GY("    passwd: not cracked")
      end if
      if h.hasIndex("ehash") and (wh=="e" or wh=="a") then
        p=crypto.decipher(h.ehash)
        if p then _p GN("    email  -> ")+YL(p) else _p GY("    email: not cracked")
      end if
      if h.hasIndex("bhash") and (wh=="b" or wh=="a") then
        p=crypto.decipher(h.bhash)
        if p then _p GN("    bank   -> ")+YL(p) else _p GY("    bank: not cracked")
      end if
    end for
  end while
end function
_digFS=function(results,fn)
  prt("Searching "+_s(results.len)+" machines for "+fn+"...")
  found=[]
  for r in results;c2=r.ex;for f in getAllFiles(c2);if f.name==fn then;found.push({"ip":r.ip,"path":f.path,"file":f});_p GN("  [+] ")+YL(r.ip)+GY(" ")+WH(f.path);end if;end for;end for
  if not found then prt("File not found on any machine")
end function
_digW=function(results)
  wiped=0
  for r in results
    c2=r.ex
    bf=c2.File("/boot")
    if not bf or not _hp(bf,"w") then continue
    for f in bf.get_files;if _hp(f,"w") then f.delete;end for
    wiped=wiped+1
    _p RD("  [x] ")+YL(r.ip)+GY(" /boot wiped")
  end for
  _ps(_s(wiped)+"/"+_s(results.len)+" machines wiped")
end function
_digA=function(shell,task)
  bounce=_digBo(shell)
  if not bounce then return _pe("No bounce found")
  _ps(bounce.ln+" ["+bounce.addr+"] "+bounce.user)
  results=_digX(shell,bounce,false)
  if not results then return _pe("No machines")
  _ps(_s(results.len)+" hosts")
  if task=="e" then
    _digE(results)
  else if task=="bk" then
    _digB(results)
  else if task=="u" then
    _digU(results)
  else if task=="s" then
    fn=_uig("[filename] > ")
    if not fn or not fn.trim.len then return
    _digFS(results,fn.trim)
  end if
end function
_recon=function(_tip,task="d")
  hMetax=_scn.metax
  if not hMetax then return _pe("Scan metaxploit not loaded")
  if not _hasNet(_lc) then return _pe("No internet connection")
  prt("Recon: "+_tip+":0...")
  ses=hMetax.net_use(_tip)
  if not ses then return _pe("Cannot connect to "+_tip+":0")
  lib=ses.dump_lib
  if not lib then return _pe("Cannot dump lib "+_tip+":0")
  addrs=hMetax.scan(lib)
  if not addrs then return _pe("No exploits on "+_tip+":0")
  shell=null
  bns=[]
  for addr in addrs
    vi=hMetax.scan_address(lib,addr)
    if not vi then continue
    for line in vi.split(char(10))
      if line.indexOf(_uc)!=0 then continue
      s=line.indexOf("<b>")+3
      d=line.indexOf("</b>")
      if s<=2 or d==null then continue
      val=line[s:d]
      ex=lib.overflow(addr,val)
      if not ex then continue
      obj=_to(ex)
      if obj==_sh or obj==_fs then
        if not shell or _gu(ex)=="root" then shell=ex
      else if obj==_cm then
        usr=_gu(ex)
        bns.push({"lib":lib,"addr":addr,"val":val,"user":usr,"ln":lib_name(lib)})
        _p GN("  [bounce] ")+GY(addr+" -> ")+WH(usr)
      end if
    end for
  end for
  if bns.len and shell then
    sb=[];ub=[];gb=[]
    for b in bns;if b.user=="root" then;sb.push(b);else if b.user==_gt then;gb.push(b);else;ub.push(b);end if;end for
    bns=sb+ub+gb
    _ps(_s(bns.len)+" bounce(s) on edge router")
    _p _hr
    for i in range(0,bns.len);b=bns[i];_p GN("  ["+_s(i+1)+"] ")+WH(b.user)+GY(" — "+b.addr);end for
    _p GN("  [s] ")+GY("Skip — full dig")
    _p _hr
    sel=_uig("[# or s] > ")
    if sel and _tl(sel)!="s" then
      idx=sel.trim.val-1
      if idx>=0 and idx<bns.len then
        best=bns[idx]
        _ps("Shell: "+_gu(shell)+" on "+_HC(shell).public_ip)
        _ps("Bounce: "+best.ln+" ["+best.addr+"] "+best.user)
        res=_digX(shell,best,false)
        if not res then return _pe("No machines")
        _ps(_s(res.len)+" hosts")
        if task!="d" then return _digA(shell,task)
        while true
          if gco.H then break
          ch=_uig("[e,bk,u,s,sw,x] > ")
          if not ch then continue
          ch=_tl(ch)
          if ch=="x" then return
          if ch=="e" then _digE(res)
          if ch=="bk" then _digB(res)
          if ch=="u" then _digU(res)
          if ch=="sw" then _digW(res)
          if ch=="s" then
            fn=_uig("[filename] > ")
            if fn and fn.trim.len then _digFS(res,fn.trim)
          end if
        end while
      end if
    end if
  else if bns.len then
    _pw(_s(bns.len)+" bounce(s) but no shell for LAN")
  end if
  if not shell then return _pe("No shell on router")
  _ps(_gu(shell)+" shell on "+_HC(shell).public_ip)
  if task=="d" then return _digS(shell)
  _digA(shell,task)
end function
_digS=function(shell)
  comp=_HC(shell)
  if not comp.File("/lib/kernel_router.so") then return _pe("you must be on a router to run dig")
  lip=comp.local_ip
  if lip==homeLIP then router=_gr else router=_grR(shell)
  if not router then return _pe("No router found")
  if not router then return _pe("No router found")
  lanIPs=router.devices_lan_ip
  if not lanIPs then return _pe("No LAN devices found")
  testIP=null
  while true
    if gco.H then break
    _p OR(_hb("DIG"))
    tLine=GY("  Router: ")+YL(router.public_ip)+GY(" LAN: ")+YL(lip)
    if testIP then tLine=tLine+GY(" Test: ")+YL(testIP)
    _p tLine
    _p _mi("e","  Grab emails")
    _p _mi("bk"," Grab bank accounts")
    _p _mi("u","  Grab user data (passwd+email+bank)")
    _p _mi("rt"," Grab root password")
    _p _mi("r","  Grab rshell data")
    _p _mi("s","  Search for file")
    _p _mi("sw"," System wipe (remove /boot)")
    _p _mi("t","  Set test IP (bounce target)")
    _p _mi("cl"," Clear dig cache (force rescan)")
    _p _bk
    c=_uig("[dig] > ")
    if not c or _tl(c)=="b" then break
    ch=_tl(c)
    if ch=="t" then
      ti=_uig("[test IP (blank=auto)] > ")
      if ti and len(ti.trim) then testIP=ti.trim else testIP=null
    else if ch=="cl" then
      if dc.hasIndex(_ck) then dc.remove(_ck)
      _ps("Cache cleared for "+_ck)
    else if ch!="e" and ch!="bk" and ch!="u" and ch!="rt" and ch!="r" and ch!="s" and ch!="sw" then
      _pe("Invalid option")
    else
    fn=null
    if ch=="s" then
      fn=_uig("[filename] > ")
      if not fn or not len(fn.trim) then continue
      fn=fn.trim
    end if
    if ch=="sw" then
      ans=_ui(RD("[!] This will wipe /boot on ALL LAN machines. Type YES > "))
      if ans!="YES" then
        prt("Cancelled")
        continue
      end if
    end if
    exAns=_uig("[extreme? Also sweep subnets 0-255] (y/N) > ")
    extreme=exAns and _tl(exAns)=="y"
    _ck=router.public_ip
    if not gco.hasIndex("digCache") then gco.digCache={}
    dc=gco.digCache
    bounce=null
    libDir=_HC(shell).File("/lib")
    libCount=0
    if libDir then libCount=len(libDir.get_files)
    if dc.hasIndex(_ck) and dc[_ck].bounce then
      if dc[_ck].hasIndex("libCount") and dc[_ck].libCount!=libCount then
        _ps("Libraries changed — rescanning bounce")
        dc.remove(_ck)
      else
        bounce=dc[_ck].bounce
        _ps("Using cached bounce: "+bounce.ln+" ["+bounce.addr+"] as "+bounce.user)
      end if
    end if
    if not bounce then
      bounce=_digBo(shell,testIP)
      if not bounce then
        _pe("No bounce exploit found in /lib")
        continue
      end if
      if not dc.hasIndex(_ck) then dc[_ck]={}
      dc[_ck].bounce=bounce
      dc[_ck].libCount=libCount
      _ps("Using: "+bounce.ln+" ["+bounce.addr+"] as "+bounce.user)
    end if
    if ch=="rt" then
      testTarget=null
      if testIP then testTarget=testIP
      if not testTarget then
        for ip in lanIPs;if ip!=lip then;testTarget=ip;break;end if;end for
      end if
      if not testTarget then
        _pe("No LAN target")
        continue
      end if
      ex=bounce.lib.overflow(bounce.addr,bounce.val,testTarget)
      if not ex or _to(ex)!=_cm then
        _pe("Could not get computer from "+testTarget)
        continue
      end if
      pf=ex.File("/etc/passwd")
      if not pf or not _hp(pf,"r") then
        _pe("Cannot read /etc/passwd")
        continue
      end if
      content=_gc(pf)
      if not content then
        _pe("Empty passwd file")
        continue
      end if
      for line in content.split(char(10))
        if not line then continue
        parts=line.split(":")
        if parts.len>=2 and parts[0]=="root" then
          _p OR("ROOT: ")+GY(parts[1])
          if crypto then
            rp=crypto.decipher(parts[1])
            if rp then
              _p GN("  -> ")+YL(rp)
              _acr(shell,"root",rp)
              _ps("Added root:"+rp+" to cache")
            else
              _p GY("  (not cracked)")
            end if
          end if
          break
        end if
      end for
      continue
    end if
    results=null
    exKey="results"
    if extreme then exKey="results_ex"
    if dc[_ck].hasIndex(exKey) then
      results=dc[_ck][exKey]
      _ps("Using cached results: "+_s(results.len)+" machines")
    else
      results=_digX(shell,bounce,extreme)
      if not results then
        _pe("No machines compromised")
        continue
      end if
      dc[_ck][exKey]=results
    end if
    _ps(_s(results.len)+" machines compromised")
    if ch=="e" then
      _digE(results)
    else if ch=="bk" then
      _digB(results)
    else if ch=="u" then
      _digU(results)
    else if ch=="r" then
      _digR(results)
    else if ch=="s" then
      _digFS(results,fn)
    else if ch=="sw" then
      _digW(results)
    end if
    end if
  end while
end function
_cpw=function(ex)
  pf=getFileEx(ex,"/etc/passwd")
  if not pf then return 0
  c=_gc(pf)
  if not c then return 0
  n=0
  for line in c.split(char(10));if not line or not line.len then continue;pp=line.split(":");if pp.len<2 then continue;n=n+1;end for
  return n
end function
_cap=function(ex)
  comp=_HC(ex)
  n=0
  dirs=["/usr/bin","/bin"]
  for d in dirs;df=comp.File(d);if not df then continue;n=n+df.get_files.len;end for
  hf=comp.File("/home")
  if hf then
    for ud in hf.get_folders;if ud.name==_gt then continue;for f in ud.get_files;if f.name.indexOf(".exe")!=null then n=n+1;end for;end for
  end if
  return n
end function
_gcr=function(sh)
  lip=_HC(sh).local_ip
  r=[]
  if gco.hasIndex("_eip") and gco._eip and gco._nc.hasIndex(gco._eip) then r=r+gco._nc[gco._eip]
  if gco._nc.hasIndex(lip) then r=r+gco._nc[lip]
  return r
end function
_gcr2=function(ex,exType)
  if exType==_sh then
    lip=_HC(ex).local_ip
  else if exType==_cm then
    lip=ex.local_ip
  else
    return []
  end if
  r=[]
  if gco.hasIndex("_eip") and gco._eip and gco._nc.hasIndex(gco._eip) then r=r+gco._nc[gco._eip]
  if gco._nc.hasIndex(lip) then r=r+gco._nc[lip]
  return r
end function
_acr2=function(ip,u,p)
  if not ip or not p then return
  k=ip
  if u=="root" then k=gco._eip
  if not gco._nc.hasIndex(k) then gco._nc[k]=[]
  for c in gco._nc[k];if c.user==u then return;end for
  gco._nc[k].push({"user":u,"pass":p})
end function
_acr=function(sh,u,p);_acr2(_HC(sh).local_ip,u,p);end function
_loadDevLib=function(shell,libName)
  comp=_HC(shell)
  pip=comp.public_ip
  lip=comp.local_ip
  dk="dev_"+libName
  if gco.hasIndex(dk) and gco[dk] then return gco[dk]
  f=comp.File("/lib/"+libName)
  if not f then return null
  u=_gu(shell)
  home=_hd(u)
  if gco.hasIndex(dk) then gco[dk]=null
  code="get_custom_object["""+dk+"""]=include_lib(""/lib/"+libName+""")"
  comp.touch(comp,home,".x_d.src")
  sf=comp.File(home+"/.x_d.src")
  if not sf then return null
  sf.set_content(code)
  r=shell.build(path(sf),home)
  if r!="" then
    sf=comp.File(home+"/.x_d.src")
    if sf then qrm(comp,sf)
    return null
  end if
  shell.launch(home+"/.x_d")
  sf=comp.File(home+"/.x_d.src")
  if sf then qrm(comp,sf)
  sf=comp.File(home+"/.x_d")
  if sf then qrm(comp,sf)
  if not gco.hasIndex(dk) or not gco[dk] then return null
  result=gco[dk]
  return result
end function
_loadRemoteLib=function(shell,libPath)
  comp=_HC(shell)
  f=comp.File(libPath)
  if not f then return _pe("Not found: "+libPath)
  u=_gu(shell)
  home=_hd(u)
  dk="rlib_"+libPath
  gco[dk]=null
  code="l=include_lib("""+libPath+""");if l then get_custom_object["""+dk+"""]=l;get_custom_object[""rlib_type""]=typeof(l)"
  comp.touch(home,".x_rl.src")
  sf=comp.File(home+"/.x_rl.src")
  if not sf then return _pe("Failed to create loader")
  sf.set_content(code)
  r=shell.build(path(sf),home)
  if r!="" then
    sf=comp.File(home+"/.x_rl.src")
    if sf then qrm(comp,sf)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_rl")
  sf=comp.File(home+"/.x_rl.src")
  if sf then qrm(comp,sf)
  sf=comp.File(home+"/.x_rl")
  if sf then qrm(comp,sf)
  if not gco.hasIndex(dk) or not gco[dk] then return _pe("Failed to load: "+libPath)
  lib=gco[dk]
  lt=gco.rlib_type
  mk=comp.public_ip+":"+comp.local_ip
  if lt=="MetaxploitLib" then
    gco.metas[mk]=lib
    _ps("Loaded remote metaxploit: "+libPath)
  else if lt=="cryptoLib" then
    _ps("Loaded remote crypto: "+libPath)
  else
    _ps("Loaded "+lt+": "+libPath)
  end if
end function
_devMenu=function(shell)
  if not shell then return _pe(_ns)
  comp=_HC(shell)
  pip=comp.public_ip
  lip=comp.local_ip
  while true
    if gco.H then break
    _p OR(_hb("Devices"))
    _p _mi("sa"," Smart Appliance (port 1883)")
    _p _mi("tf"," Traffic Net (port 37777)")
    _p _bk
    dc=_uig("[devices] > ")
    if not dc or _tl(dc)=="b" then break
    _dc=_tl(dc)
    if _dc=="sa" then
      prt("Loading libsmartappliance.so...")
      sa=_loadDevLib(shell,"libsmartappliance.so")
      if not sa then
        _pe("libsmartappliance.so not found on target")
        continue
      end if
      while true
        if gco.H then break
        _p OR("--- Smart Appliance ---")
        _p _mi("m","  Model ID")
        _p _mi("o","  Override settings (power/temp)")
        _p _mi("a","  Toggle alarm")
        _p _bk
        sc=_uig("[appliance] > ")
        if not sc or _tl(sc)=="b" then break
        _sc=_tl(sc)
        if _sc=="m" then
          r=sa.model
          if r then _p GY("  Model: ")+YL(_s(r)) else _pe("Failed")
        else if _sc=="o" then
          pw=_uig("[power (default 500)] > ")
          tp=_uig("[temperature (default 50)] > ")
          p=500
          t=50
          if pw and len(pw.trim) then p=_ti(pw.trim)
          if tp and len(tp.trim) then t=_ti(tp.trim)
          r=sa.override_settings(p,t)
          if r==1 then _pe("Override successful","s") else prt("Failed: "+_s(r))
        else if _sc=="a" then
          en=_uig("[enable alarm? y/N] > ")
          v=0
          if en and _tl(en)=="y" then v=1
          r=sa.set_alarm(v)
          if r==1 then _pe("Alarm "+["disabled","enabled"][v],"s") else prt("Failed: "+_s(r))
        end if
      end while
    else if _dc=="tf" then
      prt("Loading libtrafficnet.so...")
      tf=_loadDevLib(shell,"libtrafficnet.so")
      if not tf then
        _pe("libtrafficnet.so not found on target")
        continue
      end if
      while true
        if gco.H then break
        _p OR("--- Traffic Net ---")
        _p _mi("c","  Camera system (open viewer)")
        _p _mi("v","  Locate vehicle")
        _p _mi("i","  Get NPC credentials")
        _p _bk
        tc=_uig("[traffic] > ")
        if not tc or _tl(tc)=="b" then break
        _tc=_tl(tc)
        if _tc=="c" then
          r=tf.camera_link_system
          if r==1 then _pe("Camera broadcast initiated","s") else prt("Failed: "+_s(r))
        else if _tc=="v" then
          pl=_uig("[license plate] > ")
          if not pl or not len(pl.trim) then continue
          pw=_uig("[password] > ")
          if not pw then pw=""
          r=tf.locate_vehicle(pl.trim,pw)
          if r==1 then _pe("Vehicle found!","s") else prt("Result: "+_s(r))
        else if _tc=="i" then
          r=tf.get_credentials_info
          if r then _p GY("  ")+YL(_s(r)) else _pe("Failed")
        end if
      end while
    end if
  end while
end function
_wifiCrack=function(sh=null)
  cr=_scn.crypto
  if not cr then cr=crypto
  if not cr then return _pe("crypto.so not loaded")
  if not sh then sh=get_shell
  comp=_HC(sh)
  if comp.active_net_card!="WIFI" then return _pe("WiFi not active")
  nets=comp.wifi_networks("wlan0")
  if not nets then return _pe("No networks found")
  _p OR(_hb("WiFi Networks"))
  i=1
  for n in nets;p=n.split(" ");_p YL("  "+_lj(_s(i),4))+GN(_lj(p[0],20))+WH(_lj(p[1],6))+GY(p[2]);i=i+1;end for
  _p GY("  [a] Crack all  [#] Crack one  [q] Cancel")
  ch=_uig("[wifi] > ")
  if not ch or ch.lower=="q" then return
  targets=[]
  if ch.lower=="a" then
    targets=nets
  else
    sn=_ti(ch)
    if not sn isa number or sn<1 or sn>nets.len then return _pe("Invalid")
    targets.push(nets[sn-1])
  end if
  r=cr.airmon("start","wlan0")
  if r isa string then return _pe(r)
  if not r then return _pe("airmon failed")
  cracked=[]
  for n in targets
    p=n.split(" ")
    bssid=p[0];pwr=p[1];essid=p[2]
    s=_ti(pwr.replace("%",""))
    acks=ceil(300000/(s+15))
    prt("Cracking "+essid+" ("+bssid+") ACKs:"+_s(acks)+"...")
    cr.aireplay(bssid,essid,acks)
    capPath="/home/"+active_user+"/file.cap"
    pw=cr.aircrack(capPath)
    cf=comp.File(capPath)
    if cf then cf.delete
    if pw and pw!="null" then
      _p GN("  [+] ")+WH(essid)+GN(" => ")+YL(pw)
      cracked.push({"bssid":bssid,"essid":essid,"pass":pw})
    else
      _p RD("  [-] ")+GY(essid+" failed")
    end if
  end for
  if not cracked.len then return _pe("No passwords cracked")
  _p ""
  _p GY("Connect? [#] or [q]")
  i=1
  for c in cracked;_p YL("  "+_s(i)+"  ")+GN(c.essid);i=i+1;end for
  while true
    if gco.H then break
    ch=_uig("[connect] > ")
    if not ch or not len(ch.trim) then continue
    if ch.lower=="q" then return
    sn=_ti(ch)
    if sn isa number and sn>=1 and sn<=cracked.len then
      c=cracked[sn-1]
      prt("Connecting to "+c.essid+"...")
      r=comp.connect_wifi("wlan0",c.bssid,c.essid,c.pass)
      if r isa string then _pe(r) else _ps("Connected to "+c.essid)
      return
    end if
  end while
end function
_whois=function(target)
  if not target then return _pe("Usage: whois <ip or domain>")
  if target[:3]=="www" then
    target=nslookup(target)
    if target=="Not found" then return _pe("Invalid web address")
  end if
  if not _vi(target) then
    resolved=nslookup(target)
    if not resolved then return _pe("Cannot resolve: "+target)
    target=resolved
  end if
  info={}
  _lc=_HC(_ls)
  if _hasNet(_lc) then
    router=_gr(target)
    if router then
      info.BSSID=router.bssid_name
      info.ESSID=router.essid_name
    end if
  end if
  whoisData=whois(target)
  if indexOf(whoisData,"Domain name")==null then return _pe(whoisData)
  whoisData=whoisData.replace("Domain name: ","")
  whoisData=whoisData.replace("Administrative contact: ","")
  whoisData=whoisData.replace("Email address: ","")
  whoisData=whoisData.replace("Phone: ","")
  lines=split(whoisData,char(10))
  info.web=lines[0]
  info.ip=target
  info.domain=lines[0].replace("www.","")
  info.email=lines[2]
  info.admin=lines[1]
  info.phone=lines[3]
  info.company=info.web.split("\.")[1]
  _p ""
  if info.hasIndex("BSSID") then _p BL("BSSID ------------ : ")+YL(info.BSSID)
  if info.hasIndex("ESSID") then _p BL("ESSID ------------ : ")+YL(info.ESSID)
  _p BL("COMPANY PUBLIC IP  : ")+YL(info.ip)
  _p BL("COMPANY WEBSITE -- : ")+YL(info.web)
  _p BL("COMPANY DOMAIN --- : ")+YL(info.domain)
  _p BL("COMPANY NAME ----- : ")+YL(info.company)
  _p BL("ADMIN NAME ------- : ")+YL(info.admin)
  _p BL("ADMIN EMAIL ------ : ")+YL(info.email)
  _p BL("ADMIN PHONE ------ : ")+YL(info.phone)
  if lines.len>4 then
    i=4
    _len=lines.len
    while i<_len;if len(trim(lines[i])) then _p BL("INFO ------------- : ")+YL(lines[i]);i=i+1;end while
  end if
  _p ""
end function
_showHelp=function
  _p _hr
  _p GN("                     x Scanner — Help")
  _p _hr
  _p ""
  _p OR("  Navigation")
  _p GY("    # select  b back  x exit  ? help")
  _p ""
  _p OR("  Main Menu")
