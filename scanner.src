  _p GY("    echo       create: echo text > file  append: echo text >> file")
  _p GY("    Root pass  works network-wide across LAN")
  _p GY("    Shells     enable local scan, LAN scan, pivot")
  _p GY("    0day       even months, days 1-14")
  _p _hr
  _p ""
end function
getRandomIP=function
  while true
    a=floor(rnd*255)+1
    b=floor(rnd*255)
    c=floor(rnd*255)
    d=floor(rnd*255)+1
    ip=a+"."+b+"."+c+"."+d
    if a==10 then continue
    if a==172 and b>=16 and b<=31 then continue
    if a==192 and b==168 then continue
    if a==127 then continue
    if a==0 or a>=224 then continue
    return ip
  end while
end function
_loadLib=function(libPath)
  libPath=libPath.trim
  lib=include_lib(libPath)
  if not lib then return _pe("Failed to load: "+libPath)
  t=_to(lib)
  if t=="MetaxploitLib" then
    metax=lib
    metaxPath=libPath
    _n=_cur
    _n.metax=metax
    _n.metaxPath=metaxPath
    homeLIP=_HC(get_shell).local_ip
    if homeLIP then gco.metas[homeLIP]=metax
    if not isPivot then
      gco.home.metax=metax
      gco.home.metaxPath=metaxPath
    end if
    _ps("Loaded metaxploit: "+libPath)
  else if t=="cryptoLib" then
    crypto=lib
    _cur.crypto=crypto
    if not isPivot then gco.home.crypto=crypto
    _ps("Loaded crypto: "+libPath)
  else
    _pe("Unknown lib type: "+t)
  end if
end function
_selfPath=program_path
_selfParts=_selfPath.split("/")
_selfName=_selfParts[_selfParts.len-1]
_initShell=get_shell
_initUser=_gu(_initShell)
if _initUser=="root" then _payDir="/root/payload" else _payDir="/home/"+_initUser+"/payload"
isPivot=false
for arg in params;if arg=="pivot" then isPivot=true;end for
_init=function
  outer.metax=include_lib("/lib/metaxploit.so")
  outer.metaxPath=null
  if metax then
    outer.metaxPath="/lib/metaxploit.so"
  else
    outer.metax=include_lib(_payDir+_mx)
    if metax then
      outer.metaxPath=_payDir+_mx
    else
      outer.metax=include_lib(current_path+_mx)
      if metax then outer.metaxPath=current_path+_mx
    end if
  end if
  outer.crypto=include_lib("/lib/crypto.so")
  if not crypto then outer.crypto=include_lib(_payDir+"/crypto.so")
  if not crypto then outer.crypto=include_lib(current_path+"/crypto.so")
  outer._ls=_initShell
  outer._lc=_HC(_ls)
  _node={"shell":_ls,"metax":metax,"metaxPath":metaxPath,"crypto":crypto,"ip":_lc.public_ip,"lip":_lc.local_ip}
  gco.metas={}
  gco.routers={}
  gco._nc={}
  if not isPivot then
    gco.home=_node
    if not gco.hasIndex("pivots") then gco.pivots=[]
  else
    if not gco.hasIndex("pivots") then gco.pivots=[]
    gco.pivots.push(_node)
  end if
  gco.H=false
  if not gco.hasIndex("rshell_servers") then gco.rshell_servers={}
  if not gco.hasIndex("rshell_shells") then gco.rshell_shells=[]
  if not gco.hasIndex("neuro_creds") then gco.neuro_creds=null
  outer.homeLIP=_lc.local_ip
  if metax and homeLIP then gco.metas[homeLIP]=metax
  if metax then _ps("Loaded metaxploit: "+metaxPath) else _pe("metaxploit.so not found")
  if crypto then _ps("Loaded crypto") else _pe("crypto.so not found")
end function
_init
quickMode=false
_am=true
_tip=null
for arg in params;if arg=="pivot" then continue;if arg=="-r" then;_tip=getRandomIP;else if arg=="-q" then;quickMode=true;else;if not _tip and arg.indexOf("-")!=0 then _tip=arg;end if;end for
if not isPivot then
  for a in params
    al=a.lower
    if al=="-po" then
      _pObjectMenu
      exit
    else if al=="-nr" then
      _neuroScan
      exit
    else if al=="-dg" or al=="-dig" then
      _digS(_ls)
      exit
    else if al=="-ls" then
      localScan(_ls)
      exit
    else if al=="-ns" then
      scanLAN(_ls)
      exit
    else if al=="-wf" then
      _wifiCrack
      exit
    else if al=="-rc" then
      rcIP=_tip
      if not rcIP then rcIP=_uig("[recon target IP] > ")
      if rcIP and _vi(rcIP.trim) then
        _p OR(_hb("Recon"))
        _p _mi("e","  Emails")
        _p _mi("bk"," Bank accounts")
        _p _mi("u","  User data (passwd)")
        _p _mi("s","  Search file")
        _p _mi("d","  Full dig menu")
        ch=_uig("[task] > ")
        if ch then _recon(rcIP.trim,_tl(ch))
      end if
      exit
    end if
  end for
end if
_scanTarget=function(_tip)
  gco._eip=_tip
  gco.metas={}
  gco.routers={}
  if metax then gco.metas[homeLIP]=metax
  gco.meta_local=null
  if gco.hasIndex("packRootShell") then gco.packRootShell=null
  if gco.hasIndex("scanlan_result") then gco.scanlan_result=null
  gco._nc={}
  if not _hasNet(_HC(_ls)) then return _pe("No internet connection")
  router=_gr(_tip)
  if not router then return _pe("No route to "+_tip)
  _p ""
  _p LG("Scanner v1.0 — "+current_date)
  _p LG("Target: "+_tip)
  _p ""
  ports=[0]+router.used_ports
  if ports.len>1 and _to(ports[1])==_sg then return _pe(ports[1])
  portTable=[]
  portHeader=GY(_lj("PORT",8))+GY(_lj("STATE",9))+GY(_lj("SERVICE",14))+GY(_lj("VERSION",11))+GY("LAN")
  portTable.push(portHeader)
  for port in ports
    if port==0 then
      svc="router"
      ver=router.kernel_version
      lan=router.local_ip
      state=GN(_lj("open",9))
      row=GN(_lj("0",8))+state+BL(_lj(svc,14))+BL(_lj(ver,11))+LM(lan)
      portTable.push(row)
      continue
    end if
    info=router.port_info(port).split(" ")
    svc=info[0]
    ver=info[1]
    lan=port.get_lan_ip
    portNum=_pn(port)
    if port.is_closed then state=RD(_lj("closed",9)) else state=GN(_lj("open",9))
    row=GN(_lj(_s(portNum),8))+state+BL(_lj(svc,14))+BL(_lj(ver,11))+LM(lan)
    portTable.push(row)
  end for
  if quickMode then
    for row in portTable;_p row;end for
    return
  end if
  lanDevices=router.devices_lan_ip
  allTargets=[]
  gco._nc={}
  while true
    if gco.H then break
    _p ""
    _p LG("Target: "+_tip)
    for row in portTable;_p row;end for
    if lanDevices and lanDevices.len>0 then
      _p ""
      _p GY("  LAN Devices (")+GN(_s(lanDevices.len))+GY("):")
      for ld in lanDevices;ldPorts=router.device_ports(ld);pList=[];for p in ldPorts;pList.push(_s(_pn(p)));end for;pStr="";if pList then pStr=GY(" ports:")+WH(pList.join(","));_p GY("    ")+YL(ld)+pStr;end for
    end if
    if allTargets then
      prt("Previously scanned:")
      for tgt in allTargets
        i=__tgt_idx+1
        total=tgt.shells+tgt.computers+tgt.files+tgt.bounces+tgt.firewalls+tgt.unknown
        t=PR("[")+WH(_s(i))+PR("] ")+YL("• ")+OR(tgt.ln)+WH(" (Version: "+tgt.ver+") ")
        if tgt.port==0 then _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN("0") else _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN(_s(tgt.port))
        bd=""
        if tgt.port==0 then bd=YL(" - ")+WH("Bo")+OR(":")+PR(_s(tgt.bounces))+YL(" - ")+WH("Fw")+OR(":")+LM(_s(tgt.firewalls))
        _p "    "+WH("Sh")+OR(":")+GN(_s(tgt.shells))+YL(" - ")+WH("Co")+OR(":")+YL(_s(tgt.computers))+YL(" - ")+WH("Fi")+OR(":")+RD(_s(tgt.files))+bd+YL(" - ")+WH("Un")+OR(":")+ER(_s(tgt.unknown))
      end for
    end if
    _p ""
    if ports.len==1 and not allTargets then
      prt("Single port, auto-scanning...")
      c="a"
    else
      c=_uig("[Port #, 'a' scan all, 'b' back, '?' help, home] > ")
    end if
    if not c then continue
    if _tl(c)=="b" then break
    if c.trim=="?" then
      _showHelp
      continue
    end if
    scanPorts=[]
    if _tl(c)=="a" then
      scanPorts=ports
    else
      sel=_ti(c.trim)
      if not sel isa number then
        _pe(_iv)
        continue
      end if
      found=false
      for port in ports
        if port==0 then
          if sel==0 then
            scanPorts.push(port)
            found=true
            break
          end if
        else
          if _pn(port)==sel then
            scanPorts.push(port)
            found=true
            break
          end if
        end if
      end for
      if not found then
        if allTargets and sel>0 and sel<=allTargets.len then
          scanPorts=[]
        else
          _pe("Port not found: "+_s(sel))
          continue
        end if
      end if
    end if
    newPorts=[]
    for port in scanPorts
      pn=0
      if port!=0 then pn=_pn(port)
      already=false
      for tgt in allTargets;if tgt.port==pn then;already=true;break;end if;end for
      if not already then newPorts.push(port)
    end for
    if scanPorts and not newPorts then
      ans=_ui(YL("[!] Already scanned. Rescan? (y/N) "))
      if ans and _tl(ans)=="y" then newPorts=scanPorts
    end if
    hMetax=_scn.metax
    if newPorts and not hMetax then
      _pe("Scan metaxploit not loaded - cannot scan")
      newPorts=null
    end if
    if newPorts then
      prt("Scanning for exploits...")
      _p ""
      for port in newPorts
        portNum=0
        lan=router.local_ip
        if port!=0 then
          if port.is_closed then continue
          portNum=_pn(port)
          lan=port.get_lan_ip
        end if
        if portNum==0 then session=net_use(hMetax,router.public_ip) else session=hMetax.net_use(router.public_ip,portNum)
        if not session then continue
        lib=session.dump_lib
        if not lib then continue
        ln=lib.lib_name
        ver=lib.version
        addresses=hMetax.scan(lib)
        if not addresses then continue
        exploits=[]
        for addr in addresses
          vulnInfo=hMetax.scan_address(lib,addr)
          if not vulnInfo then continue
          for line in vulnInfo.split(char(10))
            if line.indexOf(_uc)==0 then
              s=line.indexOf("<b>")+3
              d=line.indexOf("</b>")
              if s>2 and d!=null then
                unsecured=line[s:d]
                exploits.push({"addr":addr,"val":unsecured})
              end if
            end if
          end for
        end for
        if not exploits then continue
        p=lib.is_patched(1)
        if p isa string then
          patchStr=GN("Patched To: "+p)
        else if p==1 then
          patchStr=GN("Patched")
        else
          patchStr=RD("Not Patched")
        end if
        ct={"shells":0,"computers":0,"files":0,"bounces":0,"firewalls":0,_uk:0}
        classified=[]
        for e in exploits
          ex=lib.overflow(e.addr,e.val)
          r=_classifyEx(ex,ln)
          if ct.hasIndex(r[0]+"s") then ct[r[0]+"s"]=ct[r[0]+"s"]+1 else ct.unknown=ct.unknown+1
          classified.push({"addr":e.addr,"val":e.val,"type":r[0],"user":r[1]})
        end for
        allTargets.push({"lib":lib,"ln":ln,"ver":ver,"lan":lan,"port":portNum,"session":session,"exploits":classified,"patchStr":patchStr,"shells":ct.shells,"computers":ct.computers,"files":ct.files,"bounces":ct.bounces,"firewalls":ct.firewalls,_uk:ct.unknown})
      end for
    end if
    if not allTargets then
      prt("No exploitable services found")
      if ports.len==1 then break
      continue
    end if
    while true
      if gco.H then break
      _p ""
      _p LG("Target: "+_tip)
      for row in portTable;_p row;end for
      prt("Found the following attack vectors:")
      for tgt in allTargets
        i=__tgt_idx+1
        total=tgt.shells+tgt.computers+tgt.files+tgt.bounces+tgt.firewalls+tgt.unknown
        t=PR("[")+WH(_s(i))+PR("] ")+YL("• ")+OR(tgt.ln)+WH(" (Version: "+tgt.ver+") ")
        if tgt.port==0 then _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN("0") else _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN(_s(tgt.port))
        _p GN("    |-> ")+tgt.patchStr
        _p "    "+GN(_s(total))+WH(" exploits found")
        bd=""
        if tgt.port==0 then bd=YL(" - ")+WH("Bo")+OR(":")+PR(_s(tgt.bounces))+YL(" - ")+WH("Fw")+OR(":")+LM(_s(tgt.firewalls))
        _p "    "+WH("Sh")+OR(":")+GN(_s(tgt.shells))+YL(" - ")+WH("Co")+OR(":")+YL(_s(tgt.computers))+YL(" - ")+WH("Fi")+OR(":")+RD(_s(tgt.files))+bd+YL(" - ")+WH("Un")+OR(":")+ER(_s(tgt.unknown))
      end for
      c=_uig("[Target #, 'b' back, '?' help, home] > ")
      if not c then continue
      if _tl(c)=="b" then break
      if c.trim=="?" then
        _showHelp
        continue
      end if
      sel=_ti(c.trim)
      if not sel isa number or sel<1 or sel>allTargets.len then
        _pe(_iv)
        continue
      end if
      tgt=allTargets[sel-1]
      while true
        if gco.H then break
        _p OR("--- Exploits for ")+WH(tgt.ln)+GY(":")+BL(tgt.ver)+OR(" on ")+YL(tgt.lan+":"+_s(tgt.port))+OR(" ---")
        _p GY(_lj("#",5))+GY(_lj("TYPE",12))+GY(_lj("USER",12))+GY(_lj("ADDRESS",14))+GY("VALUE")
        for e in tgt.exploits;e.i=__e_idx+1;_p _exTag(e);end for
        c2=_uig("[Exploit #, 'c' custom, 'ba' bounce all, 'b' back, '?' help, home] > ")
        if not c2 then continue
        if _tl(c2)=="b" then break
        if c2.trim=="?" then
          _showHelp
          continue
        end if
        if _tl(c2)=="c" then
          ca=_uig("[Memory address] > ")
          if not ca or not ca.trim.len then continue
          cv=_uig("[Unsafe check value] > ")
          if not cv or not cv.trim.len then continue
          ex=tgt.lib.overflow(ca.trim,cv.trim)
          _exR(ex)
          continue
        end if
        if _tl(c2)=="ba" then
          bip=_ui(OR("[Bounce target IP] > "))
          if not bip or not _vi(bip.trim) then
            _pe(_iip)
            continue
          end if
          bip=bip.trim
          for ne in tgt.exploits
            if ne.type!="null" then continue
            prt("Trying "+ne.addr+" "+ne.val+" -> "+bip)
            ex=tgt.lib.overflow(ne.addr,ne.val,bip)
            if not ex then
              _p GY("    null")
              continue
            end if
            if ex isa string then
              _p GY("    "+ex)
              continue
            end if
            _exR(ex)
          end for
          continue
        end if
        esel=_ti(c2.trim)
        if not esel isa number or esel<1 or esel>tgt.exploits.len then
          _pe(_iv)
          continue
        end if
        exploit=tgt.exploits[esel-1]
        if exploit.type=="bounce" then
          bounceIP=_ui(OR("[Enter bounce target IP] > "))
          if not bounceIP or not _vi(bounceIP.trim) then
            _pe(_iip)
            continue
          end if
          ex=tgt.lib.overflow(exploit.addr,exploit.val,bounceIP.trim)
        else if exploit.type=="null" then
          _p GY(_en)
          _p GY("  It may be a password-change exploit.")
          ans=_uig("[Password or bounce IP, or 'b' to skip] > ")
          if not ans or _tl(ans)=="b" then continue
          ex=tgt.lib.overflow(exploit.addr,exploit.val,ans.trim)
          if not ex then
            prt("Exploit returned null again")
            continue
          else if ex isa string then
            _pe(ex)
            continue
          end if
          obj=_to(ex)
          if obj==_cm then
            _ps("Got computer (bounce)!")
            _p OR(_uu)+WH(_gu(ex))
            _p OR(_uh)+WH(ex.public_ip)
            _exM(ex,_cm)
          else
            _ps("Password change may have succeeded!")
          end if
          continue
        else
          ex=tgt.lib.overflow(exploit.addr,exploit.val)
        end if
        _exR(ex)
      end while
    end while
  end while
end function
if _tip then
  if not _vi(_tip) then
    resolved=nslookup(_tip)
    if not resolved then exit(RD("[!] Cannot resolve: "+_tip))
    _tip=resolved
  end if
  _scanTarget(_tip)
  if quickMode then exit
end if
mm={}
mm.cl=function;clear_screen;end function
mm["?"]=function;_showHelp;end function
