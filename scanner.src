  _p OR("  Host Menu (after exploit)")
  _p GY("    c  crack    s  su       a  apps     ! <cmd>")
  _p GY("    f  browse   d  download r  rename   u  upload")
  _p GY("    g  grab     l  local    n  LAN      dg dig")
  _p GY("    rs rshell   pt patch    po PObject  pv pivot")
  _p GY("    dv devices  wf WiFi     0d 0day     w  wipe log")
