mm.ht=function
  if not _hasNet(_lc) then return _pe("No internet connection")
  svc=_uig("[service: ssh,ftp,http,smtp,sql,repo,rshell,cam] > ")
  if not svc or not len(svc.trim) then return
  svc=_tl(svc)
  cnt=_uig("[max IPs to scan (default 50)] > ")
  mx=50
  if cnt and _ti(cnt.trim) isa number then mx=_ti(cnt.trim)
  prt("Hunting for "+svc+" across "+_s(mx)+" random IPs...")
  found=[]
  i=0
  while i<mx
    ip=getRandomIP
    if not ip then
      i=i+1
      continue
    end if
    r=_gr(ip)
    if not r then
      i=i+1
      continue
    end if
    ports=r.used_ports
    if not ports or _to(ports)==_sg then
      i=i+1
      continue
    end if
    for p in ports
      inf=r.port_info(p)
      if not inf then continue
      if inf.lower.indexOf(svc)!=null then
        lip=p.get_lan_ip
        pip=r.public_ip
        sv=inf.split(" ")
        found.push({"ip":pip,"lip":lip,"port":_pn(p),"svc":sv[0],"ver":sv[1]})
        _p GN("  [+] ")+WH(pip)+GY(":")+YL(lip)+GY(" port ")+WH(_s(_pn(p)))+GY(" ")+OR(inf)
      end if
    end for
    i=i+1
  end while
  if not found.len then _pe("No "+svc+" services found in "+_s(mx)+" IPs") else _ps("Found "+_s(found.len)+" "+svc+" services")
end function
mm.r=function;ip=getRandomIP;if not ip then return _pe("Failed to get random IP");_scanTarget(ip);end function
while true
  gco.H=false
  _p _hr
  if isPivot then _p WH("         "+YL(_selfName)+" - "+PR("PIVOTED")+" Port & Exploit Scanner") else _p WH("              "+YL(_selfName)+" - Port & Exploit Scanner")
  _p _hr
  _p ""
  mTag=RD("not loaded")
  if metax then mTag=GN("loaded")
  cTag=RD("not loaded")
  if crypto then cTag=GN("loaded")
  _p GY("  local metax: ")+mTag+GY("  local crypto: ")+cTag
  hmTag=RD("not loaded")
  if _scn.metax then hmTag=GN("loaded")
  hcTag=RD("not loaded")
  if _scn.crypto then hcTag=GN("loaded")
  _p GY("  scan metax:  ")+hmTag+GY("  scan crypto:  ")+hcTag
  rsTag=GN(_s(gco.rshell_servers.len))+GY(" servers, ")+GN(_s(gco.rshell_shells.len))+GY(" shells")
  _p GY("  rshell: ")+rsTag
  if not _hasNet(_lc) then _p RD("  ** No internet connection")
  pvCnt=gco.pivots.len
  if pvCnt>0 then _p GY("  pivots: ")+GN(_s(pvCnt))+GY(" active")
  if isPivot then
    pComp=_HC(_ls)
    _p GY("  current: ")+GN(_gu(_ls))+GY("@")+YL(pComp.public_ip)+GY(":")+YL(pComp.local_ip)+GY(" (depth ")+GN(_s(pvCnt))+GY(")")
  end if
  _p ""
  _p GY("  Type IP or domain to scan")
  _p _mi("r","  Scan random IP")
  _p _mi("ls"," Local scan  ")+_mi("ns"," LAN scan   ")+_mi("dg"," Dig")
  _p _mi("po"," PObject     ")+_mi("wf"," WiFi       ")+_mi("rc"," Recon")
  _p _mi("ht"," Hunt        ")+_mi("pv"," Pivots     ")+_mi("h","  Host")
  rsC=gco.rshell_shells.len
  rsSrv=gco.rshell_servers.len
  _p _mi("rs"," RShell ("+_s(rsSrv)+"/"+_s(rsC)+")")
  _p _mi("e","  Echo >|>>   ")+_mi("w"," whois  ")+_mi("0d"," 0day")
  _p _mi("cm"," clear mail  ")+_mi("cl"," clear screen")
  _p _mi("?","  Help")
  _p _mi("x","  Exit")
  inp=_uig("["+_gu(_ls)+"@"+_lc.public_ip+":"+_lc.local_ip+"] > ")
  if not inp then continue
  inp=inp.trim
  if inp.lower=="x" then break
  _inp=inp.lower
  if _sw(inp,"echo ") then
    _echo(inp[5:],_HC(_ls))
  else if _sw(inp,"e ") then
    _echo(inp[2:],_HC(_ls))
  else if hasIndex(mm,_inp) then
    mm[_inp]
  else if _vi(inp) then
    _scanTarget(inp)
  else
    ip=nslookup(inp)
    if not ip then
      _pe("Cannot resolve: "+inp)
    else
      _ps(inp+" -> "+ip)
      _scanTarget(ip)
    end if
  end if
end while
