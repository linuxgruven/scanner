mm.cm=function
  eu=_uig("[email/user] > ")
  if eu and len(eu.trim) then
    ep=_uig("[password] > ")
    if ep and len(ep.trim) then
      ml2=mail_login(eu.trim,ep.trim)
      if not ml2 or _to(ml2)==_sg then
        _pe("Login failed: "+_s(ml2))
      else
        msgs=fetch(ml2)
        if not msgs or not msgs.len then
          _ps("Inbox empty")
        else
          for m in msgs;seg=split(m,char(10));if seg.len>2 then delete_mail(ml2,seg[2][8:]);end for
          _ps("Deleted "+_s(msgs.len)+" messages")
        end if
      end if
    end if
  end if
end function
